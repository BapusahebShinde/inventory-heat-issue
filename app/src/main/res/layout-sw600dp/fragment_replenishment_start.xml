<?xml version="1.0" encoding="utf-8"?>

<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
  xmlns:app="http://schemas.android.com/apk/res-auto"
  xmlns:bind="http://schemas.android.com/tools"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  android:background="@color/white"
  android:clickable="true"
  bind:context=".ui.movement.replenishment.ReplenishmentListViewModel">

  <include
    android:id="@+id/header"
    layout="@layout/header_title_layout" />

  <androidx.appcompat.widget.LinearLayoutCompat
    android:id="@+id/ll"
    android:layout_width="match_parent"
    android:layout_height="@dimen/dp_0"
    android:orientation="horizontal"
    app:layout_constraintBottom_toBottomOf="parent"
    app:layout_constraintLeft_toLeftOf="parent"
    app:layout_constraintRight_toRightOf="parent"
    app:layout_constraintTop_toBottomOf="@id/header">

    <com.itek.retail.ui.customviews.ProductDetailsView
      android:id="@+id/pdv_replenish_start"
      android:layout_width="match_parent"
      android:layout_height="match_parent"
      android:layout_weight="1" />

    <androidx.constraintlayout.widget.ConstraintLayout
      android:id="@+id/ll2"
      android:layout_width="match_parent"
      android:layout_height="match_parent"
      android:layout_weight="1"
      android:gravity="center"
      android:orientation="vertical">

      <RadioGroup
        android:id="@+id/rgPickSearchType"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="@dimen/dp_0"
        android:background="@drawable/border_bottom"
        android:orientation="horizontal"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <View
          android:layout_width="match_parent"
          android:layout_height="match_parent"
          android:layout_weight="1.3" />

        <RadioButton
          android:id="@+id/rbSearch"
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:layout_margin="@dimen/dp_5"
          android:layout_weight="1"
          android:checked="true"
          android:ellipsize="marquee"
          android:marqueeRepeatLimit="marquee_forever"
          android:singleLine="true"
          android:text="@string/search" />

        <View
          android:layout_width="match_parent"
          android:layout_height="match_parent"
          android:layout_weight="1.1" />

        <RadioButton
          android:id="@+id/rbPick"
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:layout_margin="@dimen/dp_5"
          android:layout_weight="1"
          android:ellipsize="marquee"
          android:marqueeRepeatLimit="marquee_forever"
          android:singleLine="true"
          android:text="@string/pick" />

        <View
          android:layout_width="match_parent"
          android:layout_height="match_parent"
          android:layout_weight="1.3" />
      </RadioGroup>

      <TextView
        android:id="@+id/txt_picked"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="@dimen/dp_15"
        android:layout_marginTop="@dimen/dp_5"
        android:layout_marginRight="@dimen/dp_15"
        android:layout_marginBottom="@dimen/dp_5"
        android:gravity="center"
        android:textAppearance="@style/TextStyleSubHeader"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/rgPickSearchType" />

      <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/llCircle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintBottom_toTopOf="@id/llBtnStart"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toBottomOf="@id/txt_picked">

        <com.itek.retail.ui.customviews.speedviewlib.PointerSpeedometer
          android:id="@+id/clReplenishmentSearch"
          android:layout_width="@dimen/dp_0"
          android:layout_height="@dimen/dp_0"
          app:layout_constraintBottom_toBottomOf="parent"
          app:layout_constraintDimensionRatio="1:1"
          app:layout_constraintLeft_toLeftOf="parent"
          app:layout_constraintRight_toRightOf="parent"
          app:layout_constraintTop_toTopOf="parent"
          app:layout_constraintWidth_default="percent"
          app:layout_constraintWidth_percent="0.5" />

        <com.itek.retail.ui.customviews.CountTotalView
          android:id="@+id/ctw_inventory_start"
          android:layout_width="@dimen/dp_0"
          android:layout_height="@dimen/dp_0"
          android:layout_gravity="center"
          android:background="@drawable/circular_shape"
          android:orientation="vertical"
          android:visibility="gone"
          app:layout_constraintBottom_toBottomOf="parent"
          app:layout_constraintDimensionRatio="1:1"
          app:layout_constraintLeft_toLeftOf="parent"
          app:layout_constraintRight_toRightOf="parent"
          app:layout_constraintTop_toTopOf="parent"
          app:layout_constraintWidth_default="percent"
          app:layout_constraintWidth_percent="0.45"/>

      </androidx.constraintlayout.widget.ConstraintLayout>

      <com.itek.retail.ui.customviews.BtnStartStopView
        android:id="@+id/llBtnStart"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toBottomOf="@id/llCircle" />

    </androidx.constraintlayout.widget.ConstraintLayout>

  </androidx.appcompat.widget.LinearLayoutCompat>

  <com.itek.retail.ui.customviews.BtnSwipeUploadView
    android:id="@+id/btnUpload"
    android:layout_width="wrap_content"
    android:layout_height="@dimen/dp_0"
    android:visibility="gone"
    app:layout_constraintBottom_toBottomOf="parent"
    app:layout_constraintRight_toRightOf="parent"/>
</androidx.constraintlayout.widget.ConstraintLayout>
