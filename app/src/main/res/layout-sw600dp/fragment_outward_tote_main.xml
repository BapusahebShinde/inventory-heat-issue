<?xml version="1.0" encoding="utf-8"?>
<androidx.swiperefreshlayout.widget.SwipeRefreshLayout xmlns:android="http://schemas.android.com/apk/res/android"
  xmlns:app="http://schemas.android.com/apk/res-auto"
  xmlns:tools="http://schemas.android.com/tools"
  android:id="@+id/swipeLayout"
  android:layout_width="match_parent"
  android:layout_height="wrap_content"
  android:background="@color/white"
  android:clickable="true">

  <androidx.constraintlayout.widget.ConstraintLayout
    android:id="@+id/cl_main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:clickable="true"
    tools:context=".ui.outward.tote.OutwardToteMainFragment">

    <include
      android:id="@+id/header"
      layout="@layout/header_title_layout" />

    <LinearLayout
      android:id="@+id/ll_outward_tote_data"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginLeft="@dimen/dp_15"
      android:layout_marginRight="@dimen/dp_15"
      android:orientation="vertical"
      app:layout_constraintTop_toBottomOf="@id/header">

      <!-- TODO set as AutoCompleteView -->
      <com.itek.retail.ui.customviews.InputView
        android:id="@+id/iv_dest_code"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:label="@string/lbl_destination_site"
        app:isHideLabel="false"
        app:validationRegex="[0-9A-Za-z]{1,}"
        app:inputRegex="[0-9A-Za-z]{0,}"
        app:minLength="4"
        android:maxLength="8"
        android:layout_marginTop="@dimen/dp_10"
        android:layout_marginLeft="@dimen/dp_10"
        android:layout_marginRight="@dimen/dp_10"
        android:hint="@string/hint_destination_site"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toBottomOf="@id/header"
        app:layout_constraintHeight_default="percent"
        app:layout_constraintHeight_percent="0.2"/>

      <com.itek.retail.ui.customviews.HeaderSpinner
        android:id="@+id/spin_outward_tote_type"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_weight="1"
        android:padding="@dimen/dp_10"
        android:visibility="visible"
        app:isSetOptionAll="false"
        android:entries="@array/OutwardToteTypes"
        app:label="@string/lbl_type"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toBottomOf="@id/iv_dest_code" />

<!--      <com.itek.retail.ui.customviews.ScanCodesInputAndKeypadView-->
<!--        android:id="@+id/scan_carton"-->
<!--        android:layout_width="match_parent"-->
<!--        android:layout_height="wrap_content"-->
<!--        app:isRFIDScan="false"-->
<!--        app:validationRegex="[0-9A-Za-z]+"-->
<!--        app:inputRegex="[0-9A-Za-z]*"-->
<!--        app:label="@string/lbl_carton"-->
<!--        android:hint="@string/scan_carton"-->
<!--        android:padding="@dimen/dp_10"-->
<!--        android:visibility="gone"-->
<!--        app:layout_constraintLeft_toLeftOf="parent"-->
<!--        app:layout_constraintRight_toRightOf="parent"-->
<!--        app:layout_constraintTop_toBottomOf="@id/spin_outward_tote_type" />-->

    </LinearLayout>

    <Button
      android:id="@+id/btn_proceed"
      style="@style/Button"
      android:layout_width="@dimen/dp_0"
      android:layout_height="wrap_content"
      android:layout_gravity="center"
      android:text="@string/btn_go"
      android:layout_marginTop="@dimen/dp_15"
      app:layout_constraintLeft_toLeftOf="parent"
      app:layout_constraintRight_toRightOf="parent"
      app:layout_constraintTop_toBottomOf="@id/ll_outward_tote_data"
      app:layout_constraintWidth_default="percent"
      app:layout_constraintWidth_percent="0.333" />

    <com.google.android.material.floatingactionbutton.FloatingActionButton
      android:id="@+id/btnUpload"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:layout_marginRight="@dimen/dp_5"
      android:layout_marginBottom="@dimen/dp_5"
      android:visibility="gone"
      app:backgroundTint="@color/white"
      app:layout_constraintRight_toRightOf="parent"
      app:layout_constraintTop_toTopOf="@id/btnSwipeUpload"
      app:srcCompat="@drawable/ic_upload" />

    <com.itek.retail.ui.customviews.swipeButton.ProSwipeButtonVar
      android:id="@+id/btnSwipeUpload"
      android:layout_width="@dimen/dp_0"
      android:layout_height="@dimen/dp_0"
      android:layout_marginLeft="@dimen/dp_5"
      android:layout_marginRight="@dimen/dp_5"
      android:layout_marginBottom="@dimen/dp_5"
      android:background="@drawable/bg_white_red"
      android:clickable="true"
      android:visibility="gone"
      app:btn_text=""
      app:layout_constraintBottom_toBottomOf="parent"
      app:layout_constraintHeight_default="percent"
      app:layout_constraintHeight_percent="0.25"
      app:layout_constraintLeft_toLeftOf="@id/btnUpload"
      app:layout_constraintRight_toRightOf="@id/btnUpload"
      app:layout_constraintWidth_default="percent"
      app:layout_constraintWidth_percent="0.1" />

  </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.swiperefreshlayout.widget.SwipeRefreshLayout>
