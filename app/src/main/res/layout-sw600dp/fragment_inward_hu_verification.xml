<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
  xmlns:app="http://schemas.android.com/apk/res-auto"
  xmlns:bind="http://schemas.android.com/tools"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  android:background="@color/white"
  android:clickable="true"
  bind:context=".ui.inward.huverification.InwardHuVerificationViewModel">

  <include
    android:id="@+id/header"
    layout="@layout/header_title_layout"
    app:layout_constraintLeft_toLeftOf="parent"
    app:layout_constraintRight_toRightOf="parent"
    app:layout_constraintTop_toTopOf="parent" />

  <TextView
    android:id="@+id/txt_trip_number"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_gravity="center"
    android:layout_marginLeft="@dimen/dp_15"
    android:layout_marginRight="@dimen/dp_15"
    android:background="@drawable/border_bottom"
    android:gravity="center"
    android:textAppearance="@style/TextStyleHeader"
    android:visibility="visible"
    app:layout_constraintBottom_toTopOf="@id/edt_search_hu"
    app:layout_constraintLeft_toLeftOf="parent"
    app:layout_constraintRight_toRightOf="parent"
    app:layout_constraintTop_toBottomOf="@id/header" />

  <com.itek.retail.ui.customviews.ScanCodesInputAndKeypadView
    android:id="@+id/edt_search_hu"
    android:layout_width="@dimen/dp_0"
    android:layout_height="wrap_content"
    android:layout_margin="@dimen/dp_15"
    android:hint="@string/scan_hu"
    app:label="@string/lbl_hu_number"
    app:isHUField="true"
    app:layout_constraintBottom_toTopOf="@id/btnHuVerification"
    app:layout_constraintLeft_toLeftOf="parent"
    app:layout_constraintRight_toRightOf="parent"
    app:layout_constraintTop_toBottomOf="@id/txt_trip_number"
    app:layout_constraintWidth_default="percent"
    app:layout_constraintWidth_percent="0.75" />

  <Button
    android:id="@+id/btnHuVerification"
    style="@style/Button"
    android:layout_width="@dimen/dp_0"
    android:layout_height="wrap_content"
    android:layout_gravity="center"
    android:layout_margin="@dimen/dp_10"
    android:text="@string/btn_verify_hu"
    app:layout_constraintBottom_toTopOf="@id/ll_list_header"
    app:layout_constraintLeft_toLeftOf="parent"
    app:layout_constraintRight_toRightOf="parent"
    app:layout_constraintTop_toBottomOf="@id/edt_search_hu"
    app:layout_constraintWidth_default="percent"
    app:layout_constraintWidth_percent="0.25" />

  <LinearLayout
    android:id="@+id/ll_list_header"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_gravity="center"
    android:layout_marginLeft="@dimen/dp_10"
    android:layout_marginRight="@dimen/dp_10"
    android:orientation="horizontal"
    app:layout_constraintBottom_toTopOf="@id/rv_hu_verification"
    app:layout_constraintLeft_toLeftOf="parent"
    app:layout_constraintRight_toRightOf="parent"
    app:layout_constraintTop_toBottomOf="@id/btnHuVerification">

    <TextView
      android:id="@+id/txt_inward_hu_verification_item_title"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_gravity="center"
      android:layout_margin="@dimen/dp_5"
      android:layout_weight="1"
      android:gravity="center"
      android:marqueeRepeatLimit="marquee_forever"
      android:padding="@dimen/dp_5"
      android:singleLine="true"
      android:text="@string/lbl_hu_number"
      android:textAppearance="@style/TextStyleSubHeader" />

    <TextView
      android:id="@+id/txt_inward_hu_verification_item_status"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_margin="@dimen/dp_5"
      android:layout_weight="1.5"
      android:gravity="center"
      android:maxLines="1"
      android:padding="@dimen/dp_5"
      android:singleLine="true"
      android:text="@string/lbl_grn_status"
      android:textAppearance="@style/TextStyleSubHeader" />
  </LinearLayout>

  <androidx.recyclerview.widget.RecyclerView
    android:id="@+id/rv_hu_verification"
    android:layout_width="match_parent"
    android:layout_height="@dimen/dp_0"
    android:layout_marginLeft="@dimen/dp_15"
    android:layout_marginRight="@dimen/dp_15"
    app:layout_constraintBottom_toBottomOf="parent"
    app:layout_constraintLeft_toLeftOf="parent"
    app:layout_constraintRight_toRightOf="parent"
    app:layout_constraintTop_toBottomOf="@id/ll_list_header" />

</androidx.constraintlayout.widget.ConstraintLayout>
