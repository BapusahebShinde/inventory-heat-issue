<?xml version="1.0" encoding="utf-8"?>
<androidx.swiperefreshlayout.widget.SwipeRefreshLayout xmlns:android="http://schemas.android.com/apk/res/android"
  xmlns:app="http://schemas.android.com/apk/res-auto"
  xmlns:tools="http://schemas.android.com/tools"
  android:id="@+id/swipeLayout"
  android:layout_width="match_parent"
  android:layout_height="wrap_content"
  android:background="@color/white"
  android:clickable="true">

  <androidx.constraintlayout.widget.ConstraintLayout
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:clickable="true"
    tools:context=".ui.encoding.EncodingMainFragment">

    <include
      android:id="@+id/header"
      layout="@layout/header_title_layout" />

    <include
      android:id="@+id/ll_sub_header"
      layout="@layout/header_subtitle_layout"
      app:layout_constraintTop_toBottomOf="@id/header" />

    <TextView
      android:id="@+id/lbl_encoding_main_count"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_margin="@dimen/dp_15"
      android:gravity="center"
      android:text="@string/lbl_encode_count"
      android:textAppearance="@style/TextStyleSubHeader"
      app:layout_constraintBottom_toTopOf="@id/ll_encoding_main_count"
      app:layout_constraintTop_toBottomOf="@id/ll_sub_header" />

    <LinearLayout
      android:id="@+id/ll_encoding_main_count"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_margin="@dimen/dp_15"
      android:background="@drawable/border_bottom"
      android:orientation="horizontal"
      app:layout_constraintBottom_toTopOf="@id/lbl_encoding_history"
      app:layout_constraintTop_toBottomOf="@id/lbl_encoding_main_count">

      <com.itek.retail.ui.customviews.DashboardDataView
        android:id="@+id/ddv_encode_today"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:background="@drawable/border_right"
        android:orientation="vertical"
        android:visibility="visible"
        app:isShowPercent="false"
        app:label="@string/lbl_encode_today" />

      <com.itek.retail.ui.customviews.DashboardDataView
        android:id="@+id/ddv_encode_session"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:visibility="visible"
        app:isShowPercent="false"
        app:label="@string/lbl_encode_session" />

    </LinearLayout>

    <TextView
      android:id="@+id/lbl_encoding_history"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginTop="@dimen/dp_15"
      android:gravity="center"
      android:text="@string/lbl_encode_history"
      android:textAppearance="@style/TextStyleSubHeader"
      app:layout_constraintBottom_toTopOf="@id/list_encoding_history"
      app:layout_constraintLeft_toLeftOf="parent"
      app:layout_constraintRight_toRightOf="parent"
      app:layout_constraintTop_toBottomOf="@id/ll_encoding_main_count" />

    <androidx.recyclerview.widget.RecyclerView
      android:id="@+id/list_encoding_history"
      android:layout_width="match_parent"
      android:layout_height="@dimen/dp_0"
      android:layout_margin="@dimen/dp_15"
      app:layout_constraintBottom_toTopOf="@id/lbl_refresh"
      app:layout_constraintLeft_toLeftOf="parent"
      app:layout_constraintRight_toRightOf="parent"
      app:layout_constraintTop_toBottomOf="@id/lbl_encoding_history" />

    <TextView
      android:id="@+id/lbl_refresh"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_margin="@dimen/dp_15"
      android:background="@drawable/border_bottom"
      android:gravity="center"
      android:paddingBottom="@dimen/dp_5"
      android:text="@string/msg_refresh_dashboard"
      android:textAppearance="@style/TextStyleSubSubHeader"
      android:visibility="visible"
      app:layout_constraintBottom_toBottomOf="parent"
      app:layout_constraintTop_toBottomOf="@id/list_encoding_history" />

    <ImageView
      android:id="@+id/img_list_load_more"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_gravity="center"
      android:scaleType="fitCenter"
      android:visibility="gone"
      app:layout_constraintBottom_toBottomOf="parent"
      app:layout_constraintLeft_toLeftOf="parent"
      app:layout_constraintRight_toRightOf="parent"
      app:layout_constraintTop_toBottomOf="@id/list_encoding_history"
      app:srcCompat="@drawable/ic_downarrow" />

  </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.swiperefreshlayout.widget.SwipeRefreshLayout>
