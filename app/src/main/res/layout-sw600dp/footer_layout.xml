<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
  xmlns:app="http://schemas.android.com/apk/res-auto"
  android:id="@+id/footer"
  android:layout_width="match_parent"
  android:layout_height="wrap_content"
  android:background="@color/white"
  android:orientation="horizontal"
  app:layout_constraintBottom_toBottomOf="parent"
  app:layout_constraintLeft_toLeftOf="parent"
  app:layout_constraintRight_toRightOf="parent">

  <ImageView
    android:id="@+id/img_footer"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_weight="1"
    android:padding="@dimen/dp_5"
    app:layout_constraintBottom_toBottomOf="parent"
    app:layout_constraintLeft_toLeftOf="parent"
    app:layout_constraintRight_toRightOf="parent"
    app:srcCompat="@drawable/ic_footer_itek_2026" />

  <TextClock
    android:id="@+id/textClock"
    android:layout_width="wrap_content"
    android:layout_height="match_parent"
    android:layout_gravity="center_vertical"
    android:drawableLeft="@drawable/ic_time_small"
    android:drawablePadding="@dimen/dp_2"
    android:format12Hour="dd-MMM-yyyy HH:mm"
    android:format24Hour="dd-MMM-yyyy HH:mm"
    android:gravity="center"
    android:padding="@dimen/dp_5"
    android:textAppearance="@style/TextStyleSmall"
    android:visibility="visible" />

</LinearLayout>