<?xml version="1.0" encoding="utf-8"?>

<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
  xmlns:app="http://schemas.android.com/apk/res-auto"
  xmlns:bind="http://schemas.android.com/tools"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  android:background="@color/white"
  android:clickable="true"
  app:layout_behavior="@string/appbar_scrolling_view_behavior"
  bind:context=".ui.search.listsearch.SearchListStartFragment">

  <include
    android:id="@+id/header"
    layout="@layout/header_title_layout" />

  <androidx.appcompat.widget.LinearLayoutCompat
    android:id="@+id/ll"
    android:layout_width="match_parent"
    android:layout_height="@dimen/dp_0"
    android:orientation="horizontal"
    app:layout_constraintBottom_toBottomOf="parent"
    app:layout_constraintLeft_toLeftOf="parent"
    app:layout_constraintRight_toRightOf="parent"
    app:layout_constraintTop_toBottomOf="@id/header">

    <com.itek.retail.ui.customviews.ProductDetailsView
      android:id="@+id/pdv_prod_search"
      android:layout_width="match_parent"
      android:layout_height="match_parent"
      android:layout_weight="1" />

    <androidx.constraintlayout.widget.ConstraintLayout
      android:id="@+id/ll2"
      android:layout_width="match_parent"
      android:layout_height="match_parent"
      android:layout_weight="1"
      android:gravity="center"
      android:orientation="vertical">

      <Button
        android:id="@+id/btnSizeChart"
        style="@style/Button"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="@dimen/dp_5"
        android:text="@string/tab_check_availability"
        android:visibility="gone"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toTopOf="@id/ll2" />

      <TextView
        android:id="@+id/txt_found"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="@dimen/dp_15"
        android:layout_marginRight="@dimen/dp_15"
        android:layout_weight="1"
        android:gravity="center"
        android:textAppearance="@style/TextStyleHeader"
        android:visibility="visible"
        app:layout_constraintBottom_toTopOf="@id/clProdSearch"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btnSizeChart" />

      <com.itek.retail.ui.customviews.speedviewlib.PointerSpeedometer
        android:id="@+id/clProdSearch"
        android:layout_width="@dimen/dp_0"
        android:layout_height="@dimen/dp_0"
        app:layout_constraintBottom_toTopOf="@id/llBtnStart"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btnSizeChart"
        app:layout_constraintWidth_default="percent"
        app:layout_constraintWidth_percent="0.45" />

      <com.itek.retail.ui.customviews.BtnStartStopView
        android:id="@+id/llBtnStart"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toBottomOf="@id/clProdSearch" />

      <Button
        android:id="@+id/btnMarkFound"
        style="@style/Button"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/btn_mark_found"
        android:visibility="visible"
        app:layout_constraintLeft_toRightOf="@id/llBtnStart"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toTopOf="@id/llBtnStart" />
    </androidx.constraintlayout.widget.ConstraintLayout>

  </androidx.appcompat.widget.LinearLayoutCompat>

</androidx.constraintlayout.widget.ConstraintLayout>
