<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
  xmlns:app="http://schemas.android.com/apk/res-auto"
  xmlns:bind="http://schemas.android.com/tools"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  android:background="@color/white"
  android:clickable="true"
  app:layout_behavior="@string/appbar_scrolling_view_behavior"
  bind:context=".ui.encoding.EncodingVerifyFragment">

  <include
    android:id="@+id/header"
    layout="@layout/header_title_layout" />

  <androidx.appcompat.widget.LinearLayoutCompat
    android:layout_width="match_parent"
    android:layout_height="@dimen/dp_0"
    android:orientation="horizontal"
    app:layout_constraintBottom_toBottomOf="parent"
    app:layout_constraintLeft_toLeftOf="parent"
    app:layout_constraintRight_toRightOf="parent"
    app:layout_constraintTop_toBottomOf="@+id/header">

    <androidx.appcompat.widget.LinearLayoutCompat
      android:id="@+id/ll1"
      android:layout_width="match_parent"
      android:layout_height="match_parent"
      android:layout_weight="1"
      android:orientation="vertical">

      <androidx.appcompat.widget.LinearLayoutCompat
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <View
          android:id="@+id/v1"
          android:layout_width="match_parent"
          android:layout_height="match_parent"
          android:layout_weight="1.5" />

        <com.itek.retail.ui.customviews.ScanCodesInputAndKeypadView
          android:id="@+id/scan_encoding_verify_barcode"
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:layout_marginLeft="@dimen/dp_5"
          android:layout_marginRight="@dimen/dp_5"
          android:layout_weight="1"
          app:layout_constraintLeft_toLeftOf="parent"
          app:layout_constraintRight_toRightOf="parent"
          app:layout_constraintTop_toTopOf="parent" />

        <View
          android:id="@+id/v2"
          android:layout_width="match_parent"
          android:layout_height="match_parent"
          android:layout_weight="1.5" />

      </androidx.appcompat.widget.LinearLayoutCompat>

      <Button
        android:id="@+id/btn_verify_encoding"
        style="@style/Button"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_margin="@dimen/dp_5"
        android:text="@string/btn_hu_go"
        app:layout_constraintBottom_toTopOf="@id/pdv_encoding_verify_barcode"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toBottomOf="@id/scan_encoding_verify_barcode" />

      <com.itek.retail.ui.customviews.ProductDetailsView
        android:id="@+id/pdv_encoding_verify_barcode"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_weight="1"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent" />

    </androidx.appcompat.widget.LinearLayoutCompat>

    <androidx.appcompat.widget.LinearLayoutCompat
      android:id="@+id/ll2"
      android:layout_width="match_parent"
      android:layout_height="match_parent"
      android:layout_weight="1"
      android:orientation="vertical">

      <com.itek.retail.ui.customviews.ScanCodesInputAndKeypadView
        android:id="@+id/scan_encoding_verify_rfid"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="@dimen/dp_5"
        android:layout_marginRight="@dimen/dp_5"
        android:visibility="gone"
        app:isRFIDScan="true"
        app:layout_constraintBottom_toTopOf="@id/pdv_encoding_verify_rfid"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

      <com.itek.retail.ui.customviews.ProductDetailsView
        android:id="@+id/pdv_encoding_verify_rfid"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_weight="1"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent" />

    </androidx.appcompat.widget.LinearLayoutCompat>

  </androidx.appcompat.widget.LinearLayoutCompat>

</androidx.constraintlayout.widget.ConstraintLayout>
