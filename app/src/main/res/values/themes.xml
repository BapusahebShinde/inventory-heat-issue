    <item name="android:textSize">14sp</item>
    <item name="android:textAllCaps">false</item>
  </style>

  <style name="TextStyleButton" parent="@android:style/TextAppearance.Small">
    <item name="android:fontFamily">@font/roboto_regular</item>
