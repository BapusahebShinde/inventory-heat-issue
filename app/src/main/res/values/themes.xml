<resources>
  <!-- Base application theme. -->
  <style name="Theme.Drawer" parent="Base.Theme.AppCompat.Light.DarkActionBar">
    <!-- Primary brand color. -->
    <item name="colorPrimary">@color/colorPrimaryDef</item>
    <item name="colorPrimaryDark">@color/colorPrimaryDarkDef</item>
    <item name="colorAccent">@color/colorAccentDef</item>

    <!-- Customize your theme here. -->
    <item name="drawerArrowStyle">@style/DrawerHamburgerStyle</item>
    <item name="actionOverflowButtonStyle">@style/ActionOverflowStyle</item>
  </style>

  <style name="Theme.Drawer.NoActionBar" parent="Theme.Drawer">
    <item name="windowActionBar">false</item>
    <item name="windowNoTitle">true</item>
  </style>

  <style name="Theme.Drawer.AppBarOverlay" parent="ThemeOverlay.AppCompat.Dark.ActionBar" />
  // Base.ThemeOverlay.AppCompat.Dark

  <style name="Theme.Drawer.PopupOverlay" parent="ThemeOverlay.AppCompat.Dark" />

  <style name="ActionOverflowStyle" parent="Widget.AppCompat.ActionButton.Overflow">
    <item name="android:tint">@color/icon_grey</item>
  </style>

  <style name="ActionOverflowMenuStyle" parent="@style/Widget.AppCompat.Light.ActionButton.Overflow">

  </style>

  <style name="DrawerHamburgerStyle" parent="@style/Widget.AppCompat.DrawerArrowToggle">
    <item name="spinBars">true</item>
    <item name="color">@color/icon_grey</item>
  </style>

  <style name="TabLayout" parent="Widget.Design.TabLayout">
    <item name="android:layout_width">match_parent</item>
    <item name="android:layout_height">wrap_content</item>
    <item name="background">@color/white</item>
    <item name="tabTextAppearance">@style/TextStyleSubHeader</item>
    <item name="tabIndicatorColor">?attr/colorPrimaryDark</item>
    <item name="tabTextColor">@color/colorDisabled</item>
    <item name="tabSelectedTextColor">?attr/colorPrimaryDark</item>
    <item name="tabMode">fixed</item>
    <item name="tabGravity">fill</item>
    <item name="tabMaxWidth">@dimen/dp_0</item>
  </style>

  <style name="TextConfigBtnHeader" parent="@android:style/Widget.TextView">
    <item name="android:layout_width">match_parent</item>
    <item name="android:layout_height">wrap_content</item>
    <item name="android:layout_centerHorizontal">true</item>
    <item name="android:layout_marginLeft">15dp</item>
    <item name="android:layout_marginRight">15dp</item>
    <item name="android:layout_marginTop">5dp</item>
    <item name="android:layout_marginBottom">5dp</item>
    <item name="android:layout_gravity">center</item>
    <item name="android:gravity">center</item>
    <item name="android:paddingTop">5dp</item>
    <item name="android:paddingBottom">5dp</item>
    <item name="android:background">@drawable/bg_txt_config_btn_header</item>
    <item name="singleLine">true</item>
    <item name="maxLines">1</item>
    <item name="android:textColor">@color/txt_sub_header</item>
    <item name="android:textStyle">normal</item>
    <item name="android:textSize">14sp</item>
    <item name="android:textAllCaps">false</item>
  </style>

  <style name="EditText" parent="Widget.AppCompat.EditText">
    <item name="android:layout_width">match_parent</item>
    <item name="android:layout_height">wrap_content</item>
    <item name="android:layout_weight">1</item>
    <item name="android:padding">5dp</item>
    <item name="android:textAppearance">@style/TextStyleRegular</item>
  </style>

  <style name="Button" parent="@android:style/Widget.Button">
    <item name="layout_constraintWidth_default">percent</item>
    <item name="layout_constraintWidth_percent">0.5</item>
    <item name="android:layout_width">0dp</item>
    <item name="android:layout_height">wrap_content</item>
    <item name="android:layout_centerHorizontal">true</item>
    <item name="android:layout_gravity">center</item>
    <item name="android:gravity">center</item>
    <item name="android:paddingLeft">5dp</item>
    <item name="android:paddingRight">5dp</item>
    <item name="android:paddingTop">0dp</item>
    <item name="android:paddingBottom">0dp</item>
    <item name="android:background">@drawable/button_background</item>
    <item name="singleLine">true</item>
    <item name="maxLines">1</item>
    <item name="android:fontFamily">@font/roboto_regular</item>
    <item name="android:textColor">@color/txt_button</item>
    <item name="android:textStyle">normal</item>
    <item name="android:textSize">14sp</item>
    <item name="android:textAllCaps">false</item>
  </style>

  <style name="ButtonSelectable" parent="@android:style/Widget.Button">
    <item name="layout_constraintWidth_default">percent</item>
