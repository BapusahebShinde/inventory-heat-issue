<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
  android:id="@+id/ll_verify_encoding_product_info"
  android:layout_width="match_parent"
  android:layout_height="wrap_content"
  android:layout_margin="@dimen/dp_5"
  android:background="@drawable/border"
  android:orientation="vertical"
  android:padding="@dimen/dp_5">

  <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="@dimen/dp_half"
    android:orientation="horizontal">

    <TextView
      android:id="@+id/txt_replenish_batch_date"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginRight="@dimen/dp_1"
      android:layout_weight="1.25"
      android:ellipsize="marquee"
      android:gravity="left|center_vertical"
      android:singleLine="true"
      android:text="@string/txt_ean"
      android:textAppearance="@style/TextStyleSmall" />

    <TextView
      android:id="@+id/txt_replenish_batch_status"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginLeft="@dimen/dp_1"
      android:layout_weight="2"
      android:ellipsize="marquee"
      android:gravity="left|center_vertical"
      android:singleLine="true"
      android:text="@string/txt_qty"
      android:textAppearance="@style/TextStyleSmall" />

  </LinearLayout>

  <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="@dimen/dp_half"
    android:orientation="horizontal">

    <TextView
      android:id="@+id/txt_replenish_batch_total_qty"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginRight="@dimen/dp_1"
      android:layout_weight="1.25"
      android:ellipsize="marquee"
      android:gravity="left|center_vertical"
      android:singleLine="true"
      android:text="@string/txt_name"
      android:textAppearance="@style/TextStyleSmall" />

    <TextView
      android:id="@+id/txt_replenish_batch_picked_qty"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginLeft="@dimen/dp_1"
      android:layout_marginRight="@dimen/dp_1"
      android:layout_weight="2"
      android:ellipsize="marquee"
      android:gravity="left|center_vertical"
      android:singleLine="true"
      android:text="@string/txt_size"
      android:textAppearance="@style/TextStyleSmall" />

  </LinearLayout>

</LinearLayout>
