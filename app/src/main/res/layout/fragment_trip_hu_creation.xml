<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
  xmlns:app="http://schemas.android.com/apk/res-auto"
  xmlns:bind="http://schemas.android.com/tools"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  bind:context=".ui.inward1.HuCreationFragment">

  <include
    android:id="@+id/header"
    layout="@layout/header_title_layout" />

  <LinearLayout
    android:id="@+id/ll_trip_header_titles"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="@dimen/dp_5"
    app:layout_constraintTop_toBottomOf="@id/header">

    <TextView
      android:id="@+id/txtTripNo"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_gravity="center"
      android:layout_weight="1"
      android:gravity="center"
      android:text="@string/lbl__no"
      android:textAppearance="@style/TextStyleSubSubHeader" />

    <TextView
      android:id="@+id/txtTotalHus"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_gravity="center"
      android:layout_weight="1"
      android:gravity="center"
      android:text="@string/lbl_total__s"
      android:textAppearance="@style/TextStyleSubSubHeader" />

    <TextView
      android:id="@+id/txtCompletedHus"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_gravity="center"
      android:layout_weight="1"
      android:gravity="center"
      android:text="@string/lbl_completed__s"
      android:textAppearance="@style/TextStyleSubSubHeader" />
  </LinearLayout>

  <LinearLayout
    android:id="@+id/ll_trip_header_val"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    app:layout_constraintTop_toBottomOf="@id/ll_trip_header_titles">

    <TextView
      android:id="@+id/txtTripNumber"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_weight="1"
      android:gravity="center"
      android:text="@string/default_no_value"
      android:textAppearance="@style/TextStyleNumber"
      android:textSize="@dimen/sp_14" />

    <TextView
      android:id="@+id/textTotalHu"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_weight="1"
      android:gravity="center"
      android:text="@string/default_no_value"
      android:textAppearance="@style/TextStyleNumber"
      android:textSize="@dimen/sp_14" />

    <TextView
      android:id="@+id/textCompletedHu"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_weight="1"
      android:gravity="center"
      android:text="@string/default_no_value"
      android:textAppearance="@style/TextStyleNumber"
      android:textSize="@dimen/sp_14" />

  </LinearLayout>

  <com.itek.retail.ui.customviews.ScanCodesInputAndKeypadView
    android:id="@+id/ivHuNo"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:label="@string/lbl__no"
    android:hint="@string/hint__no"
    app:isHideLabel="false"
    app:validationRegex="[0-9A-Za-z]{1,}"
    app:inputRegex="[0-9A-Za-z]{0,}"
    app:minLength="1"
    android:maxLength="20"
    android:layout_margin="@dimen/dp_15"
    app:layout_constraintLeft_toLeftOf="parent"
    app:layout_constraintRight_toRightOf="parent"
    app:layout_constraintTop_toBottomOf="@id/ll_trip_header_val"/>

  <com.itek.retail.ui.customviews.InputView
    android:id="@+id/ivExpQty"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:layout_constraintLeft_toLeftOf="parent"
    app:layout_constraintRight_toRightOf="parent"
    android:layout_margin="@dimen/dp_15"
    app:minLength="1"
    android:maxLength="4"
    app:label="@string/lbl_exp_qty"
    android:hint="@string/hint_exp_qty"
    app:isHideLabel="false"
    android:inputType="number"
    android:digits="@string/onlyDigits"
    app:validationRegex="[1-9]{1,}[0-9]{0,}"
    app:inputRegex="[0-9]{0,}"
    app:layout_constraintTop_toBottomOf="@id/ivHuNo" />

  <!--<com.itek.retail.ui.customviews.BtnStartStopView
    android:id="@+id/btnGo"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_marginTop="@dimen/dp_15"
    app:layout_constraintLeft_toLeftOf="parent"
    app:layout_constraintRight_toRightOf="parent"
    app:layout_constraintTop_toBottomOf="@id/ivExpQty" />-->

  <ImageButton
    android:id="@+id/btnGo"
    android:layout_width="0dp"
    android:layout_height="0dp"
    android:layout_gravity="center"
    android:layout_margin="@dimen/dp_15"
    android:background="@drawable/button_round_red"
    android:padding="@dimen/dp_10"
    android:text="@string/btn_proceed"
    android:textColor="@color/white"
    app:layout_constraintDimensionRatio="1:1"
    app:layout_constraintLeft_toLeftOf="parent"
    app:layout_constraintRight_toRightOf="parent"
    app:layout_constraintWidth_default="percent"
    app:layout_constraintWidth_percent="0.16"
    app:layout_constraintTop_toBottomOf="@id/ivExpQty"
    app:srcCompat="@drawable/ic_landing_proceed_arrow" />


</androidx.constraintlayout.widget.ConstraintLayout>
