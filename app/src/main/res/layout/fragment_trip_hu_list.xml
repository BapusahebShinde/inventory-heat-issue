<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
  xmlns:app="http://schemas.android.com/apk/res-auto"
  xmlns:bind="http://schemas.android.com/tools"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  bind:context=".ui.inward1.TripHUListFragment">

  <include
    android:id="@+id/header"
    layout="@layout/header_title_layout" />

  <LinearLayout
    android:id="@+id/ll_trip_header_titles"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="@dimen/dp_5"
    app:layout_constraintTop_toBottomOf="@id/header">

    <TextView
      android:id="@+id/txtTripNo"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_gravity="center"
      android:layout_weight="1"
      android:gravity="center"
      android:text="@string/lbl__no"
      android:textAppearance="@style/TextStyleSubSubHeader" />

    <TextView
      android:id="@+id/txtTotalHus"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_gravity="center"
      android:layout_weight="1"
      android:gravity="center"
      android:text="@string/lbl_total__s"
      android:textAppearance="@style/TextStyleSubSubHeader" />

    <TextView
      android:id="@+id/txtCompletedHus"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_gravity="center"
      android:layout_weight="1"
      android:gravity="center"
      android:text="@string/lbl_completed__s"
      android:textAppearance="@style/TextStyleSubSubHeader" />
  </LinearLayout>

  <LinearLayout
    android:id="@+id/ll_trip_header_val"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:background="@drawable/border_bottom"
    app:layout_constraintTop_toBottomOf="@id/ll_trip_header_titles">

    <TextView
      android:id="@+id/txtTripNumber"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_weight="1"
      android:gravity="center"
      android:text="@string/default_no_value"
      android:textAppearance="@style/TextStyleNumber"
      android:textSize="@dimen/sp_14" />

    <TextView
      android:id="@+id/textTotalHu"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_weight="1"
      android:gravity="center"
      android:text="@string/default_no_value"
      android:textAppearance="@style/TextStyleNumber"
      android:textSize="@dimen/sp_14" />

    <TextView
      android:id="@+id/textCompletedHu"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_weight="1"
      android:gravity="center"
      android:text="@string/default_no_value"
      android:textAppearance="@style/TextStyleNumber"
      android:textSize="@dimen/sp_14" />

  </LinearLayout>

  <LinearLayout
    android:id="@+id/ll_trip_header_extra_titles"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="@dimen/dp_10"
    android:orientation="horizontal"
    app:layout_constraintTop_toBottomOf="@id/ll_trip_header_val">

    <TextView
      android:id="@+id/txtTripSrcCode"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_weight="1"
      android:gravity="center"
      android:text="@string/default_no_value"
      android:textAppearance="@style/TextStyleSubSubHeader"
      android:textSize="@dimen/sp_14" />

    <TextView
      android:id="@+id/txtTripSrcType"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_weight="1"
      android:gravity="center"
      android:text="@string/default_no_value"
      android:visibility="gone"
      android:textAppearance="@style/TextStyleSubSubHeader"
      android:textSize="@dimen/sp_14" />

    <TextView
      android:id="@+id/txtTripType"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_weight="1"
      android:gravity="center"
      android:text="@string/default_no_value"
      android:textAppearance="@style/TextStyleSubSubHeader"
      android:textSize="@dimen/sp_14" />

  </LinearLayout>

  <LinearLayout
    android:id="@+id/ll_trip_header_extra_val"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:background="@drawable/border_bottom"
    app:layout_constraintTop_toBottomOf="@id/ll_trip_header_extra_titles">

    <TextView
      android:id="@+id/textTripSrcCode"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_weight="1"
      android:gravity="center"
      android:text="@string/default_no_value"
      android:textAppearance="@style/TextStyleNumber"
      android:textSize="@dimen/sp_14" />

    <TextView
      android:id="@+id/textTripSrcType"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_weight="1"
      android:gravity="center"
      android:text="@string/default_no_value"
      android:textAppearance="@style/TextStyleNumber"
      android:textSize="@dimen/sp_14" />

    <TextView
      android:id="@+id/textTripType"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_weight="1"
      android:gravity="center"
      android:text="@string/default_no_value"
      android:textAppearance="@style/TextStyleNumber"
      android:textSize="@dimen/sp_14" />

  </LinearLayout>

  <Button
    style="@style/Button"
    android:id="@+id/btnTripDetails"
    android:layout_width="0dp"
    android:layout_height="wrap_content"
    android:visibility="visible"
    android:text="@string/lbl__no"
    android:layout_margin="@dimen/dp_15"
    app:layout_constraintTop_toBottomOf="@id/ll_trip_header_extra_val"
    app:layout_constraintLeft_toLeftOf="parent"
    app:layout_constraintRight_toRightOf="parent"/>

  <com.itek.retail.ui.customviews.ScanCodesInputAndKeypadView
    android:id="@+id/ivHuNo"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:isHUField="true"
    app:label="@string/lbl__no"
    android:hint="@string/hint__no"
    app:isHideLabel="false"
    android:layout_margin="@dimen/dp_15"
    app:layout_constraintLeft_toLeftOf="parent"
    app:layout_constraintRight_toRightOf="parent"
    app:layout_constraintTop_toBottomOf="@id/btnTripDetails"/>

  <!--<com.itek.retail.ui.customviews.BtnStartStopView
    android:id="@+id/btnGo"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:gravity="center"
    android:layout_marginTop="@dimen/dp_15"
    app:layout_constraintLeft_toLeftOf="parent"
    app:layout_constraintRight_toRightOf="parent"
    app:layout_constraintTop_toBottomOf="@id/ivHuNo" />-->

  <ImageButton
    android:id="@+id/btnGo"
    android:layout_width="0dp"
    android:layout_height="0dp"
    android:layout_gravity="center"
    android:layout_margin="@dimen/dp_15"
    android:background="@drawable/button_round_red"
    android:padding="@dimen/dp_10"
    android:text="@string/btn_proceed"
    android:textColor="@color/white"
    app:layout_constraintDimensionRatio="1:1"
    app:layout_constraintLeft_toLeftOf="parent"
    app:layout_constraintRight_toRightOf="parent"
    app:layout_constraintWidth_default="percent"
    app:layout_constraintWidth_percent="0.16"
    app:layout_constraintTop_toBottomOf="@id/ivHuNo"
    app:srcCompat="@drawable/ic_landing_proceed_arrow" />

  <Button
    style="@style/Button"
    android:id="@+id/btnCompleteTrip"
    android:layout_width="0dp"
    android:layout_height="wrap_content"
    android:layout_margin="@dimen/dp_15"
    android:visibility="gone"
    app:layout_constraintTop_toBottomOf="@id/btnGo"
    app:layout_constraintLeft_toLeftOf="parent"
    app:layout_constraintRight_toRightOf="parent"/>

  <include
    android:id="@+id/hu_list_header"
    layout="@layout/hu_data_adapter"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="@dimen/dp_15"
    app:layout_constraintLeft_toLeftOf="parent"
    app:layout_constraintRight_toRightOf="parent"
    app:layout_constraintTop_toBottomOf="@id/btnCompleteTrip"/>

  <androidx.recyclerview.widget.RecyclerView
    android:id="@+id/listTripDetails"
    android:layout_width="match_parent"
    android:layout_height="@dimen/dp_0"
    app:layout_constraintBottom_toBottomOf="parent"
    app:layout_constraintTop_toBottomOf="@id/hu_list_header" />

  <TextView
    android:id="@+id/textNoData"
    android:layout_width="match_parent"
    android:layout_height="0dp"
    android:layout_gravity="center"
    android:gravity="center"
    android:text="@string/lbl_no_trip"
    app:layout_constraintTop_toBottomOf="@id/btnGo"
    app:layout_constraintBottom_toBottomOf="parent"
    android:visibility="gone" />

</androidx.constraintlayout.widget.ConstraintLayout>
