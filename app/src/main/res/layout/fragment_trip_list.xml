<?xml version="1.0" encoding="utf-8"?>
<androidx.swiperefreshlayout.widget.SwipeRefreshLayout xmlns:android="http://schemas.android.com/apk/res/android"
  xmlns:app="http://schemas.android.com/apk/res-auto"
  xmlns:bind="http://schemas.android.com/tools"
  android:id="@+id/swipeLayout"
  android:layout_width="match_parent"
  android:layout_height="wrap_content"
  android:background="@color/white"
  android:clickable="true">

<androidx.constraintlayout.widget.ConstraintLayout
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  android:background="@color/white"
  android:clickable="true"
  bind:context=".ui.inward1.TripListFragment">

  <include
    android:id="@+id/header"
    layout="@layout/header_title_layout" />

  <com.itek.retail.ui.customviews.ScanCodesInputAndKeypadView
    android:id="@+id/ivTripNo"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:label="@string/lbl__no"
    android:hint="@string/hint__no"
    app:isHUField="true"
    app:isHideLabel="false"
    app:validationRegex="[0-9A-Za-z]{1,}"
    app:inputRegex="[0-9A-Za-z]{0,}"
    app:minLength="1"
    android:maxLength="20"
    android:layout_margin="@dimen/dp_15"
    app:layout_constraintLeft_toLeftOf="parent"
    app:layout_constraintRight_toRightOf="parent"
    app:layout_constraintTop_toBottomOf="@id/header"/>

  <!--<com.itek.retail.ui.customviews.BtnStartStopView
    android:id="@+id/btnGo"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_marginTop="@dimen/dp_15"
    app:layout_constraintLeft_toLeftOf="parent"
    app:layout_constraintRight_toRightOf="parent"
    app:layout_constraintTop_toBottomOf="@id/ivTripNo" />-->

  <ImageButton
    android:id="@+id/btnGo"
    android:layout_width="0dp"
    android:layout_height="0dp"
    android:layout_gravity="center"
    android:layout_margin="@dimen/dp_15"
    android:background="@drawable/button_round_red"
    android:padding="@dimen/dp_10"
    android:text="@string/btn_proceed"
    android:textColor="@color/white"
    app:layout_constraintDimensionRatio="1:1"
    app:layout_constraintLeft_toLeftOf="parent"
    app:layout_constraintRight_toRightOf="parent"
    app:layout_constraintWidth_default="percent"
    app:layout_constraintWidth_percent="0.16"
    app:layout_constraintTop_toBottomOf="@id/ivTripNo"
    app:srcCompat="@drawable/ic_landing_proceed_arrow" />

  <include
    android:id="@+id/trip_list_header"
    layout="@layout/trip_data_adapter"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="@dimen/dp_15"
    app:layout_constraintLeft_toLeftOf="parent"
    app:layout_constraintRight_toRightOf="parent"
    app:layout_constraintTop_toBottomOf="@id/btnGo"/>

  <!--<androidx.appcompat.widget.LinearLayoutCompat
    android:id="@+id/llHeader"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    app:layout_constraintLeft_toLeftOf="parent"
    app:layout_constraintRight_toRightOf="parent"
    app:layout_constraintTop_toBottomOf="@id/btnGo">

    <TextView
      android:id="@+id/txtTripCount"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_weight="1"
      android:gravity="center"
      android:text="@string/default_no_value"
      android:textAppearance="@style/TextStyleNumber"
      android:textSize="@dimen/sp_14" />

    <TextView
      android:id="@+id/textTotalHu"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_weight="1"
      android:gravity="center"
      android:text="@string/default_no_value"
      android:textAppearance="@style/TextStyleNumber"
      android:textSize="@dimen/sp_14" />

    <TextView
      android:id="@+id/textCompletedHu"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_weight="1"
      android:gravity="center"
      android:text="@string/default_no_value"
      android:textAppearance="@style/TextStyleNumber"
      android:textSize="@dimen/sp_14" />

  </androidx.appcompat.widget.LinearLayoutCompat>-->

  <androidx.recyclerview.widget.RecyclerView
    android:id="@+id/list"
    android:layout_width="match_parent"
    android:layout_height="@dimen/dp_0"
    android:layout_margin="@dimen/dp_2"
    app:layout_constraintTop_toBottomOf="@id/trip_list_header"
    app:layout_constraintBottom_toBottomOf="parent"/>

  <TextView
    android:id="@+id/textNoData"
    android:layout_width="match_parent"
    android:layout_height="0dp"
    android:layout_gravity="center"
    android:gravity="center"
    android:text="@string/lbl_no_trip"
    app:layout_constraintTop_toBottomOf="@id/btnGo"
    app:layout_constraintBottom_toBottomOf="parent"
    android:visibility="gone" />

</androidx.constraintlayout.widget.ConstraintLayout>

</androidx.swiperefreshlayout.widget.SwipeRefreshLayout>