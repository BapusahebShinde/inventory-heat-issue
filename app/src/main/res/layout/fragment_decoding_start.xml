<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:bind="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:clickable="true"
    android:focusable="true"
    android:orientation="vertical"
    bind:context=".ui.decoding.DecodingStartFragment">

    <include
        android:id="@+id/header"
        layout="@layout/header_title_layout" />

    <com.itek.retail.ui.customviews.PowerView
        android:id="@+id/llSeekbarPower"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:gravity="center"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/header"
        app:pv_max="10"
        app:pv_min="5" />

    <LinearLayout
        android:id="@+id/ll_start_decoding_score"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintTop_toBottomOf="@id/llSeekbarPower">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/cl_start_decoding_ll_score"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/txtDecodeUploadedCount"
                style="@style/TextStyleHeader"
                android:layout_width="@dimen/dp_0"
                android:layout_height="@dimen/dp_0"
                android:layout_gravity="left"
                android:layout_marginTop="@dimen/dp_5"
                android:layout_marginBottom="@dimen/dp_5"
                android:gravity="center"
                android:text="Uploaded:\n12 / 34"
                android:visibility="gone"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintDimensionRatio="1:1"
                app:layout_constraintLeft_toLeftOf="parent"
                app:layout_constraintRight_toLeftOf="@id/ctw_inventory_start"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintWidth_default="percent"
                app:layout_constraintWidth_percent="0.33" />

            <com.itek.retail.ui.customviews.CountTotalView
                android:id="@+id/ctw_inventory_start"
                android:layout_width="@dimen/dp_0"
                android:layout_height="@dimen/dp_0"
                android:layout_gravity="center"
                android:orientation="vertical"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintDimensionRatio="1:1"
                app:layout_constraintLeft_toLeftOf="parent"
                app:layout_constraintRight_toRightOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintWidth_default="percent"
                app:layout_constraintWidth_percent="0.37"
                app:score="0"
                app:textSizeScore="@dimen/sp_30"
                app:textSizeTotal="@dimen/sp_22" />

            <SeekBar
                android:id="@+id/seek_encoding_start_target"
                android:layout_width="@dimen/dp_0"
                android:layout_height="@dimen/dp_0"
                android:layout_gravity="right"
                android:layout_marginTop="@dimen/dp_5"
                android:layout_marginBottom="@dimen/dp_5"
                android:progress="25"
                android:progressDrawable="@drawable/seekbar_target"
                android:rotation="270"
                android:visibility="visible"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintDimensionRatio="1:1"
                app:layout_constraintLeft_toRightOf="@id/ctw_inventory_start"
                app:layout_constraintRight_toRightOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintWidth_default="percent"
                app:layout_constraintWidth_percent="0.33" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <TextView
            android:id="@+id/lbl_decoding_total"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginLeft="@dimen/dp_15"
            android:layout_marginRight="@dimen/dp_15"
            android:background="@drawable/border_bottom"
            android:gravity="center"
            android:paddingBottom="@dimen/dp_2"
            android:text="@string/lbl_decode_target"
            android:textColor="@color/txt_regular"
            android:textStyle="normal"
            app:layout_constraintBottom_toTopOf="@id/scan_encoding_start_rfid"
            app:layout_constraintTop_toBottomOf="@id/ll_start_encoding_score" />

    </LinearLayout>

    <com.itek.retail.ui.customviews.BtnStartStopView
        android:id="@+id/llBtnStart"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_margin="@dimen/dp_15"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toBottomOf="@id/ll_start_decoding_score" />

    <TextView
        android:id="@+id/lbl_decoding_start_history"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="@dimen/dp_15"
        android:gravity="center"
        android:text="@string/lbl_encode_history"
        android:textAppearance="@style/TextStyleSubHeader"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toBottomOf="@id/llBtnStart" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/list_decoding_start_history"
        android:layout_width="match_parent"
        android:layout_height="@dimen/dp_0"
        android:layout_marginLeft="@dimen/dp_15"
        android:layout_marginTop="@dimen/dp_0"
        android:layout_marginRight="@dimen/dp_15"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toBottomOf="@id/lbl_decoding_start_history" />

    <ImageView
        android:id="@+id/img_list_load_more"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scaleType="fitCenter"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/list_decoding_start_history"
        app:srcCompat="@drawable/ic_downarrow" />

</androidx.constraintlayout.widget.ConstraintLayout>
