<?xml version="1.0" encoding="utf-8"?>

<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
  xmlns:app="http://schemas.android.com/apk/res-auto"
  android:layout_width="match_parent"
  android:layout_height="wrap_content"
  android:background="@color/white"
  android:orientation="horizontal"
  android:padding="@dimen/dp_2_half">

  <TextView
    android:id="@+id/txt_history_item_title"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_gravity="center"
    android:layout_margin="@dimen/dp_2"
    android:layout_weight="1"
    android:textAppearance="@style/TextStyleRegular"
    android:textColor="@color/txt_light" />

  <ImageView
    android:id="@+id/img_history_rfid"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layout_gravity="center"
    android:layout_weight="3"
    android:scaleType="fitCenter"
    android:visibility="visible"
    app:srcCompat="@drawable/ic_rfid_light" />

  <ImageView
    android:id="@+id/img_history_info"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layout_gravity="center"
    android:layout_weight="3"
    android:scaleType="fitCenter"
    android:visibility="gone"
    app:srcCompat="@drawable/ic_list_info" />
</LinearLayout>
