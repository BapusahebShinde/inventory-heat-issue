<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
  xmlns:app="http://schemas.android.com/apk/res-auto"
  android:id="@+id/ll_verify_encoding_product_info"
  android:layout_width="wrap_content"
  android:layout_height="wrap_content"
  android:background="@color/white"
  android:foregroundGravity="center"
  android:padding="@dimen/dp_5">

  <TextView
    android:id="@+id/txt_product_color"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layout_gravity="center"
    android:gravity="center"
    android:padding="@dimen/dp_1"
    android:textAppearance="@style/TextStyleRegular" />

  <ImageView
    android:id="@+id/img_product_color_selected"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layout_gravity="center"
    android:padding="@dimen/dp_5"
    android:scaleType="fitCenter"
    app:srcCompat="@drawable/ic_completed_white" />
</FrameLayout>