<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
  xmlns:app="http://schemas.android.com/apk/res-auto">

  <!--<data>

    <variable
      name="listModel"
      type="com.itek.retail.model.ListModel" />
  </data>-->

  <LinearLayout
    android:id="@+id/llSearchList"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <TextView
      android:id="@+id/txtSearchListHeader"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:background="@drawable/border_except_bottom"
      android:gravity="center"
      android:layout_marginTop="@dimen/dp_5"
      android:paddingTop="@dimen/dp_5"
      android:paddingBottom="@dimen/dp_5"
      android:textAppearance="@style/TextStyleHeader"
      android:visibility="gone"
      app:layout_constraintLeft_toLeftOf="parent"
      app:layout_constraintRight_toRightOf="parent" />

    <LinearLayout
      android:id="@+id/llFields"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_gravity="center"
      android:padding="@dimen/dp_5"
      android:orientation="horizontal">

      <TextView
        android:id="@+id/txtSearchListCode"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginRight="@dimen/dp_2_half"
        android:layout_weight="1.65"
        android:padding="@dimen/dp_2_half"
        android:layout_gravity="center_vertical"
        android:ellipsize="marquee"
        android:marqueeRepeatLimit="marquee_forever"
        android:singleLine="true"
        android:textAppearance="@style/TextStyleSubHeader" />

      <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_weight="1.35"
        android:orientation="horizontal">

      <TextView
        android:id="@+id/txtSearchListQty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="@dimen/dp_2_half"
        android:layout_marginRight="@dimen/dp_1_half"
        android:layout_weight="1"
        android:padding="@dimen/dp_2_half"
        android:layout_gravity="center_vertical"
        android:ellipsize="marquee"
        android:marqueeRepeatLimit="marquee_forever"
        android:singleLine="true"
        android:visibility="gone"
        android:textAppearance="@style/TextStyleSubSubHeader" />

      <TextView
        android:id="@+id/txtSearchListPriority"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="@dimen/dp_2_half"
        android:layout_marginRight="@dimen/dp_2_half"
        android:layout_weight="1"
        android:padding="@dimen/dp_2_half"
        android:layout_gravity="center_vertical"
        android:ellipsize="marquee"
        android:marqueeRepeatLimit="marquee_forever"
        android:singleLine="true"
        android:visibility="gone"
        android:textAppearance="@style/TextStyleSubSubHeader" />

      </LinearLayout>

      <ImageView
        android:id="@+id/img_next"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_weight="2.5"
        android:layout_marginLeft="@dimen/dp_2_half"
        android:rotation="180"
        android:scaleType="fitCenter"
        android:visibility="visible"
        app:srcCompat="@drawable/ic_back_arrow" />
    </LinearLayout>
  </LinearLayout>
</layout>