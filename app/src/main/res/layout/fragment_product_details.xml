<?xml version="1.0" encoding="utf-8"?>

<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
  xmlns:app="http://schemas.android.com/apk/res-auto"
  xmlns:bind="http://schemas.android.com/tools"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  android:background="@color/white"
  android:clickable="true"
  app:layout_behavior="@string/appbar_scrolling_view_behavior"
  bind:context=".ui.search.productsearch.ProductDetailsFragment">

  <include
    android:id="@+id/header"
    layout="@layout/header_title_layout" />

  <com.itek.retail.ui.customviews.ProductDetailsView
    android:id="@+id/pdv_prod_search"
    android:layout_width="match_parent"
    android:layout_height="@dimen/dp_0"
    android:layout_margin="@dimen/dp_5"
    app:isVerticalView="true"
    app:layout_constraintBottom_toTopOf="@id/btnSizeChart"
    app:layout_constraintLeft_toLeftOf="parent"
    app:layout_constraintRight_toRightOf="parent"
    app:layout_constraintTop_toBottomOf="@id/header" />

  <Button
    android:id="@+id/btnSizeChart"
    style="@style/Button"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_margin="@dimen/dp_5"
    android:text="@string/tab_check_availability"
    android:visibility="gone"
    app:layout_constraintBottom_toBottomOf="parent"
    app:layout_constraintLeft_toLeftOf="parent"
    app:layout_constraintRight_toRightOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
