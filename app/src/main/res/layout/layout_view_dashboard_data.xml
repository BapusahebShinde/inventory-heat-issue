<?xml version="1.0" encoding="utf-8"?>

<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
  android:layout_width="match_parent"
  android:layout_height="wrap_content"
  android:gravity="center"
  android:orientation="vertical"
  android:paddingTop="@dimen/dp_10">

  <TextView
    android:id="@+id/txt_header"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_gravity="center"
    android:layout_weight="1"
    android:gravity="center"
    android:maxLines="1"
    android:singleLine="true"
    android:textAppearance="@style/TextStyleSubHeader"
    android:visibility="gone" />

  <LinearLayout
    android:id="@+id/ll_data"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_weight="1"
    android:gravity="center"
    android:orientation="horizontal">

    <TextView
      android:id="@+id/txt_data"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_gravity="center"
      android:layout_weight="1"
      android:ellipsize="marquee"
      android:gravity="center"
      android:marqueeRepeatLimit="marquee_forever"
      android:padding="@dimen/dp_5"
      android:singleLine="true"
      android:textAppearance="@style/TextStyleNumber" />

    <LinearLayout
      android:id="@+id/ll_divider_symbol"
      android:layout_width="@dimen/dp_20"
      android:layout_height="match_parent"
      android:layout_marginLeft="@dimen/dp_neg_10"
      android:layout_marginRight="@dimen/dp_neg_10"
      android:orientation="vertical"
      android:visibility="visible">

      <View
        android:layout_width="@dimen/dp_half"
        android:layout_height="match_parent"
        android:layout_gravity="center"
        android:layout_weight="1"
        android:background="@color/txtGray"
        android:rotation="34.51" />
    </LinearLayout>

    <TextView
      android:id="@+id/txt_data_outof"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_gravity="center"
      android:layout_weight="1"
      android:ellipsize="marquee"
      android:gravity="center"
      android:marqueeRepeatLimit="marquee_forever"
      android:padding="@dimen/dp_5"
      android:singleLine="true"
      android:textAppearance="@style/TextStyleNumber"
      android:visibility="visible" />

  </LinearLayout>

  <LinearLayout
    android:id="@+id/ll_lbl"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center"
    android:orientation="horizontal"
    android:paddingTop="@dimen/dp_5"
    android:paddingBottom="@dimen/dp_5">

    <TextView
      android:id="@+id/txt_label"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_gravity="center"
      android:layout_weight="1"
      android:gravity="center"
      android:maxLines="1"
      android:singleLine="true"
      android:text="@string/lbl_orders_per_hr"
      android:textAppearance="@style/TextStyleSubHeader" />

    <TextView
      android:id="@+id/txt_label_divider"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:layout_gravity="center"
      android:gravity="center"
      android:maxLines="1"
      android:singleLine="true"
      android:text=" / "
      android:textAppearance="@style/TextStyleSubHeader" />

    <TextView
      android:id="@+id/txt_label2"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_gravity="center"
      android:layout_weight="1"
      android:gravity="center"
      android:maxLines="1"
      android:singleLine="true"
      android:text="@string/lbl_orders_per_hr"
      android:textAppearance="@style/TextStyleSubHeader" />

  </LinearLayout>

  <TextView
    android:id="@+id/txt_percent"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_gravity="center"
    android:gravity="center"
    android:maxLines="1"
    android:paddingTop="@dimen/dp_5"
    android:paddingBottom="@dimen/dp_5"
    android:singleLine="true"
    android:textAppearance="@style/TextStyleRegular"
    android:textColor="@color/txtGreen" />

  <!--
  \u2191 = up arrow
  \u2193 = down arrow
  \u2B61 = up arrow
  \u2B63 = down arrow
  -->
</LinearLayout>
