<?xml version="1.0" encoding="utf-8"?>
<androidx.swiperefreshlayout.widget.SwipeRefreshLayout xmlns:android="http://schemas.android.com/apk/res/android"
  xmlns:app="http://schemas.android.com/apk/res-auto"
  xmlns:bind="http://schemas.android.com/tools"
  android:id="@+id/swipeLayout"
  android:layout_width="match_parent"
  android:layout_height="wrap_content"
  android:background="@color/white"
  android:clickable="true">

  <androidx.constraintlayout.widget.ConstraintLayout
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:clickable="true"
    bind:context=".ui.search.omnichannel.OmniChannelFragment">

    <include
      android:id="@+id/header"
      layout="@layout/header_title_layout" />

    <include
      android:id="@+id/ll_sub_header"
      layout="@layout/header_subtitle_layout"
      app:layout_constraintTop_toBottomOf="@id/header" />

    <RadioGroup
      android:id="@+id/rgOmniChannelType"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:orientation="horizontal"
      app:layout_constraintTop_toBottomOf="@id/ll_sub_header">

      <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_weight="1.3" />

      <RadioButton
        android:id="@+id/rb_order"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="@dimen/dp_5"
        android:layout_weight="1"
        android:checked="true"
        android:ellipsize="marquee"
        android:marqueeRepeatLimit="marquee_forever"
        android:singleLine="true"
        android:tag="@string/omni_type_order"
        android:text="@string/omni_type_order" />

      <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_weight="1.1" />

      <RadioButton
        android:id="@+id/rb_ean"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="@dimen/dp_5"
        android:layout_weight="1"
        android:ellipsize="marquee"
        android:marqueeRepeatLimit="marquee_forever"
        android:singleLine="true"
        android:tag="@string/omni_type_ean"
        android:text="@string/omni_type_ean" />

      <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_weight="1.3" />
    </RadioGroup>

    <LinearLayout
      android:id="@+id/mainLayout"
      android:layout_width="match_parent"
      android:layout_height="@dimen/dp_0"
      android:gravity="center"
      android:orientation="horizontal"
      app:layout_constraintBottom_toBottomOf="parent"
      app:layout_constraintTop_toBottomOf="@+id/rgOmniChannelType">

      <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_weight="1.25"
        android:orientation="vertical">

        <com.itek.retail.ui.customviews.DashboardDataView
          android:id="@+id/ddv_today"
          android:layout_width="match_parent"
          android:layout_height="match_parent"
          android:layout_weight="1"
          android:background="@drawable/border_bottom"
          android:gravity="center"
          android:orientation="vertical"
          android:text="-"
          android:visibility="invisible"
          app:isUpwardArrow="true"
          app:percent="10" />

        <com.itek.retail.ui.customviews.DashboardDataView
          android:id="@+id/ddv_completed"
          android:layout_width="match_parent"
          android:layout_height="match_parent"
          android:layout_weight="1"
          android:gravity="top"
          android:text="-"
          app:isUpwardArrow="true"
          app:labelColor="@color/txtGreen"
          app:percent="7" />

        <androidx.recyclerview.widget.RecyclerView
          android:id="@+id/listTimeRecordsCompleted"
          android:layout_width="match_parent"
          android:layout_height="match_parent"
          android:layout_weight="1"
          android:scrollbars="vertical"
          android:visibility="gone"
          app:layout_behavior="@string/appbar_scrolling_view_behavior" />

        <View
          android:layout_width="match_parent"
          android:layout_height="match_parent"
          android:layout_weight="1"
          android:visibility="visible" />

      </LinearLayout>

      <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:background="@color/txtSuperExtraLighterGray"
        android:orientation="vertical">

        <com.itek.retail.ui.customviews.DashboardDataView
          android:id="@+id/ddv_pending"
          android:layout_width="match_parent"
          android:layout_height="match_parent"
          android:layout_weight="1.3"
          android:gravity="center"
          android:orientation="vertical"
          android:text="-"
          app:isUpwardArrow="false"
          app:labelColor="@color/txtRed"
          app:percent="5"
          app:percentColor="@color/txtGreen" />

        <androidx.recyclerview.widget.RecyclerView
          android:id="@+id/listTimeRecordsPending"
          android:layout_width="match_parent"
          android:layout_height="match_parent"
          android:layout_weight="1"
          android:scrollbars="vertical"
          app:layout_behavior="@string/appbar_scrolling_view_behavior" />
      </LinearLayout>

    </LinearLayout>

  </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.swiperefreshlayout.widget.SwipeRefreshLayout>
