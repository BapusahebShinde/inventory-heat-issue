<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
  xmlns:app="http://schemas.android.com/apk/res-auto">

  <data>
    <variable
      name="assortCodeModel"
      type="com.itek.retail.model.ProductModel" />
  </data>

  <LinearLayout
    android:id="@+id/llAssortCode"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/border_top_bottom"
    android:orientation="horizontal"
    android:paddingTop="@dimen/dp_5"
    android:paddingBottom="@dimen/dp_5">

    <com.itek.retail.ui.customviews.SortHeaderView
      android:id="@+id/txt_assort_code"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_gravity="center_vertical"
      android:layout_margin="@dimen/dp_2"
      android:layout_weight="1.25"
      android:ellipsize="marquee"
      android:gravity="center"
      android:singleLine="true"
      android:text="@string/lbl_code_no"
      android:textAppearance="@style/TextStyleRegular"
      app:sortColumn="order_no" />

    <com.itek.retail.ui.customviews.SortHeaderView
      android:id="@+id/txt_assort_qty"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_gravity="center_vertical"
      android:layout_margin="@dimen/dp_2"
      android:layout_weight="1.75"
      android:ellipsize="marquee"
      android:gravity="center"
      android:singleLine="true"
      android:text="@string/lbl_qty"
      android:textAppearance="@style/TextStyleRegular"
      app:sortColumn="qty" />

    <com.itek.retail.ui.customviews.SortHeaderView
      android:id="@+id/txt_assort_priority"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_gravity="center_vertical"
      android:layout_margin="@dimen/dp_2"
      android:layout_weight="1.5"
      android:ellipsize="marquee"
      android:gravity="center"
      android:singleLine="true"
      android:text="@string/lbl_priority"
      android:textAppearance="@style/TextStyleRegularAwesome"
      app:sortColumn="priority" />

    <ImageView
      android:id="@+id/img_next"
      android:layout_width="match_parent"
      android:layout_height="match_parent"
      android:layout_margin="@dimen/dp_2"
      android:layout_weight="2"
      android:rotation="180"
      android:scaleType="fitCenter"
      android:visibility="invisible"
      app:srcCompat="@drawable/ic_back_arrow" />

  </LinearLayout>
</layout>