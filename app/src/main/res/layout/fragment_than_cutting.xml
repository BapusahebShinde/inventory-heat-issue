<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
  xmlns:app="http://schemas.android.com/apk/res-auto"
  xmlns:bind="http://schemas.android.com/tools"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  android:background="@color/white"
  android:clickable="true"
  android:focusable="true"
  android:orientation="vertical"
  bind:context=".ui.decoding.DecodingStartFragment">

  <include
    android:id="@+id/header"
    layout="@layout/header_title_layout" />

  <androidx.constraintlayout.widget.ConstraintLayout
    android:id="@+id/clProdDtls"
    android:layout_width="match_parent"
    android:layout_height="0dp"
    android:background="@color/white"
    android:clickable="true"
    android:visibility="visible"
    app:layout_behavior="@string/appbar_scrolling_view_behavior"
    app:layout_constraintBottom_toBottomOf="parent"
    app:layout_constraintLeft_toLeftOf="parent"
    app:layout_constraintRight_toRightOf="parent"
    app:layout_constraintTop_toBottomOf="@id/header">

    <com.itek.retail.ui.customviews.ProductDetailsView
      android:id="@+id/pdv_than"
      android:background="@drawable/border_bottom_dark"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      app:lbl_weight="1.0"
      app:layout_constraintTop_toTopOf="parent"
      app:layout_constrainedHeight="true"
      app:layout_constraintHeight_max="wrap"
      app:layout_constraintHeight_percent="0.5"/>

    <com.itek.retail.ui.customviews.InputView
      android:id="@+id/iv_than_len"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:paddingTop="@dimen/dp_10"
      android:layout_margin="@dimen/dp_15"
      android:maxLength="8"
      android:inputType="numberDecimal"
      android:digits="@string/onlyDigitsDecimal"
      app:unit="@string/unit_cm"
      app:validationRegex="((0\\.[1-9][0-9]|0\\.0[1-9])|([1-9][0-9]{0,4}|[1-9][0-9]{0,4}\\.[0-9]{1,2}))"
      app:inputRegex="((0{0}|0|0\\.[0-9]{0,2})|([1-9]{0}|[1-9][0-9]{0,4}|[1-9][0-9]{0,4}\\.[0-9]{0,2}))"
      android:hint="@string/hint_than_length_cutting"
      app:isHideLabel="false"
      app:label="@string/lbl_than_length_cutting"
      app:layout_constraintLeft_toLeftOf="parent"
      app:layout_constraintRight_toRightOf="parent"
      app:layout_constraintTop_toBottomOf="@id/pdv_than"
      app:layout_constraintBottom_toTopOf="@id/btnSet"
      app:minLength="1" />

    <Button
      android:id="@+id/btnSet"
      style="@style/Button"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:layout_margin="@dimen/dp_15"
      android:gravity="center"
      android:text="@string/btn_submit"
      app:layout_constraintTop_toBottomOf="@id/iv_than_len"
      app:layout_constraintLeft_toLeftOf="parent"
      app:layout_constraintRight_toRightOf="parent"
      app:layout_constraintBottom_toBottomOf="parent"
      android:visibility="visible" />

  </androidx.constraintlayout.widget.ConstraintLayout>

  <androidx.constraintlayout.widget.ConstraintLayout
    android:id="@+id/clPickHistory"
    android:layout_width="match_parent"
    android:layout_height="0dp"
    android:background="@color/white"
    android:clickable="true"
    android:visibility="gone"
    app:layout_behavior="@string/appbar_scrolling_view_behavior"
    app:layout_constraintBottom_toBottomOf="parent"
    app:layout_constraintLeft_toLeftOf="parent"
    app:layout_constraintRight_toRightOf="parent"
    app:layout_constraintTop_toBottomOf="@id/header">

    <com.itek.retail.ui.customviews.PowerView
      android:id="@+id/llSeekbarPower"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_margin="@dimen/dp_15"
      android:visibility="gone"
      app:layout_constraintTop_toTopOf="parent"
      app:pv_max="30"
      app:pv_min="5" />

    <com.itek.retail.ui.customviews.BtnStartStopView
      android:id="@+id/llBtnStart"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:layout_gravity="center"
      android:layout_margin="@dimen/dp_15"
      android:layout_weight="1"
      android:gravity="center"
      android:orientation="vertical"
      app:layout_constraintLeft_toLeftOf="parent"
      app:layout_constraintRight_toRightOf="parent"
      app:layout_constraintTop_toBottomOf="@id/llSeekbarPower" />

    <TextView
      android:id="@+id/txt_total"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginLeft="@dimen/dp_15"
      android:layout_marginTop="@dimen/dp_5"
      android:layout_marginRight="@dimen/dp_15"
      android:layout_marginBottom="@dimen/dp_5"
      android:gravity="center"
      android:text="@string/lbl_scan_tag"
      android:textAppearance="@style/TextStyleSubHeader"
      android:visibility="visible"
      app:layout_constraintLeft_toLeftOf="parent"
      app:layout_constraintRight_toRightOf="parent"
      app:layout_constraintTop_toBottomOf="@id/llBtnStart" />

    <androidx.recyclerview.widget.RecyclerView
      android:id="@+id/list_history"
      android:layout_width="match_parent"
      android:layout_height="@dimen/dp_0"
      android:layout_marginLeft="@dimen/dp_15"
      android:layout_marginTop="@dimen/dp_0"
      android:layout_marginRight="@dimen/dp_15"
      android:visibility="visible"
      app:layout_constraintBottom_toBottomOf="parent"
      app:layout_constraintLeft_toLeftOf="parent"
      app:layout_constraintRight_toRightOf="parent"
      app:layout_constraintTop_toBottomOf="@id/txt_total" />

  </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
