<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
  xmlns:app="http://schemas.android.com/apk/res-auto">

  <!--<data>
    <variable
      name="productModel"
      type="com.itek.retail.model.ProductModel" />
  </data>-->

<LinearLayout
  android:layout_width="match_parent"
  android:layout_height="wrap_content"
  android:layout_margin="@dimen/dp_5"
  android:orientation="vertical">

  <LinearLayout
      android:id="@+id/llHead"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:background="@drawable/border_except_bottom"
      android:orientation="vertical"

      android:visibility="visible">

  <LinearLayout
    android:id="@+id/llHeader"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="@dimen/dp_5"
    android:visibility="visible">

    <TextView
      android:id="@+id/txt_header_article"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginLeft="@dimen/dp_5"
      android:layout_marginRight="@dimen/dp_1"
      android:layout_weight="1"
      android:ellipsize="marquee"
      android:gravity="left|center_vertical"
      android:marqueeRepeatLimit="marquee_forever"
      android:singleLine="true"
      android:text="@string/txt_article_no"
      android:textAppearance="@style/TextStyleRegular" />

    <TextView
      android:id="@+id/txt_order_qty"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginLeft="@dimen/dp_1"
      android:layout_marginRight="@dimen/dp_1"
      android:layout_weight="1.5"
      android:ellipsize="marquee"
      android:gravity="left|center_vertical"
      android:marqueeRepeatLimit="marquee_forever"
      android:singleLine="true"
      android:text="@string/txt_total"
      android:visibility="gone"
      android:textAppearance="@style/TextStyleRegular" />

    <TextView
      android:id="@+id/txt_available_qty"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginLeft="@dimen/dp_1"
      android:layout_marginRight="@dimen/dp_5"
      android:layout_weight="1.75"
      android:ellipsize="marquee"
      android:gravity="center|center_vertical"
      android:marqueeRepeatLimit="marquee_forever"
      android:singleLine="true"
      android:text="@string/txt_picked_qty"
      android:textAppearance="@style/TextStyleRegular" />

    <ImageView
      android:id="@+id/imgNextInvisible"
      android:layout_width="match_parent"
      android:layout_height="match_parent"
      android:layout_marginLeft="@dimen/dp_1_half"
      android:layout_marginRight="@dimen/dp_5"
      android:layout_weight="2.25"
      android:rotation="180"
      android:scaleType="fitCenter"
      android:visibility="gone"
      app:srcCompat="@drawable/ic_back_arrow" />

  </LinearLayout>

  <LinearLayout
    android:id="@+id/llHeader1"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="@dimen/dp_5"
    android:visibility="visible">

    <TextView
        android:id="@+id/txt_header_matkl"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="@dimen/dp_5"
        android:layout_marginRight="@dimen/dp_1"
        android:layout_weight="1"
        android:ellipsize="marquee"
        android:gravity="left|center_vertical"
        android:marqueeRepeatLimit="marquee_forever"
        android:singleLine="true"
        android:text="@string/lbl_matkl"
        android:textAppearance="@style/TextStyleRegular" />

    <TextView
        android:id="@+id/txt_header_category"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="@dimen/dp_5"
        android:layout_marginRight="@dimen/dp_1"
        android:layout_weight="1.5"
        android:ellipsize="marquee"
        android:gravity="left|center_vertical"
        android:marqueeRepeatLimit="marquee_forever"
        android:singleLine="true"
        android:text="@string/lbl_category"
        android:textAppearance="@style/TextStyleRegular" />



  </LinearLayout>

  <LinearLayout
      android:id="@+id/llHeader2"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:orientation="horizontal"
      android:padding="@dimen/dp_5"
      android:visibility="visible">

    <TextView
        android:id="@+id/txt_header_color"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="@dimen/dp_5"
        android:layout_marginRight="@dimen/dp_1"
        android:layout_weight="1"
        android:ellipsize="marquee"
        android:gravity="left|center_vertical"
        android:marqueeRepeatLimit="marquee_forever"
        android:singleLine="true"
        android:text="@string/lbl_color"
        android:textAppearance="@style/TextStyleRegular" />

    <TextView
        android:id="@+id/txt_header_size"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="@dimen/dp_5"
        android:layout_marginRight="@dimen/dp_1"
        android:layout_weight="1.5"
        android:ellipsize="marquee"
        android:gravity="left|center_vertical"
        android:marqueeRepeatLimit="marquee_forever"
        android:singleLine="true"
        android:text="@string/lbl_size"
        android:textAppearance="@style/TextStyleRegular" />

  </LinearLayout>

  <LinearLayout
    android:id="@+id/llHeader3"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="@dimen/dp_5"
    android:visibility="visible">

    <TextView
        android:id="@+id/txt_header_desc"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="@dimen/dp_5"
        android:layout_marginRight="@dimen/dp_1"
        android:layout_weight="1"
        android:ellipsize="marquee"
        android:gravity="left|center_vertical"
        android:marqueeRepeatLimit="marquee_forever"
        android:singleLine="true"
        android:text="@string/lbl_description"
        android:textAppearance="@style/TextStyleRegular" />

  </LinearLayout>

  </LinearLayout>

  <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/border_top"
    android:orientation="horizontal"
    android:padding="@dimen/dp_5"
    android:visibility="visible">

    <TextView
      android:id="@+id/txt_footer_ean"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginLeft="@dimen/dp_5"
      android:layout_marginRight="@dimen/dp_1_half"
      android:layout_weight="1"
      android:ellipsize="marquee"
      android:gravity="left|center_vertical"
      android:marqueeRepeatLimit="marquee_forever"
      android:singleLine="true"
      android:text="@string/txt_ean"
      android:textAppearance="@style/TextStyleRegular" />

    <TextView
      android:id="@+id/txt_total_qty"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_gravity="center"
      android:layout_margin="@dimen/dp_1_half"
      android:layout_weight="1.5"
      android:ellipsize="marquee"
      android:gravity="center"
      android:visibility="gone"
      android:marqueeRepeatLimit="marquee_forever"
      android:singleLine="true"
      android:text="@string/txt_total"
      android:textAppearance="@style/TextStyleRegular" />

    <TextView
      android:id="@+id/txt_found_qty"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_gravity="center"
      android:layout_margin="@dimen/dp_1_half"
      android:layout_weight="1.75"
      android:ellipsize="marquee"
      android:gravity="center"
      android:marqueeRepeatLimit="marquee_forever"
      android:singleLine="true"
      android:text="@string/txt_picked_qty"
      android:textAppearance="@style/TextStyleRegular" />

    <ImageView
      android:id="@+id/img_next"
      android:layout_width="match_parent"
      android:layout_height="match_parent"
      android:layout_marginLeft="@dimen/dp_1_half"
      android:layout_marginRight="@dimen/dp_5"
      android:layout_weight="2.25"
      android:rotation="180"
      android:scaleType="fitCenter"
      android:visibility="visible"
      app:srcCompat="@drawable/ic_back_arrow" />

  </LinearLayout>

</LinearLayout>
</layout>