<?xml version="1.0" encoding="utf-8"?>
<androidx.swiperefreshlayout.widget.SwipeRefreshLayout xmlns:android="http://schemas.android.com/apk/res/android"
  xmlns:app="http://schemas.android.com/apk/res-auto"
  xmlns:bind="http://schemas.android.com/tools"
  android:id="@+id/swipeLayout"
  android:layout_width="match_parent"
  android:layout_height="wrap_content"
  android:background="@color/white"
  android:clickable="true">

  <androidx.constraintlayout.widget.ConstraintLayout
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:clickable="true"
    bind:context=".ui.inward.InwardMainViewModel">

    <include
      android:id="@+id/header"
      app:layout_constraintTop_toTopOf="parent"
      app:layout_constraintLeft_toLeftOf="parent"
      app:layout_constraintRight_toRightOf="parent"
      layout="@layout/header_title_layout" />

    <include
      android:id="@+id/ll_sub_header"
      layout="@layout/header_subtitle_layout"
      app:layout_constraintLeft_toLeftOf="parent"
      app:layout_constraintRight_toRightOf="parent"
      app:layout_constraintTop_toBottomOf="@id/header" />

    <LinearLayout
      android:id="@+id/llDashboardInw"
      android:layout_width="match_parent"
      android:layout_height="@dimen/dp_0"
      android:orientation="horizontal"
      app:layout_constraintLeft_toLeftOf="parent"
      app:layout_constraintRight_toRightOf="parent"
      app:layout_constraintBottom_toBottomOf="parent"
      app:layout_constraintTop_toBottomOf="@id/ll_sub_header">

      <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:background="@color/white"
        android:orientation="vertical"
        app:srcCompat="@drawable/border">

        <TextView
          android:id="@+id/lblInwMainTrips"
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:background="@drawable/border_bottom"
          android:gravity="center"
          android:padding="@dimen/dp_10"
          android:text="@string/lbl_grn_trips"
          android:textAppearance="@style/TextStyleSubSubHeader" />

        <com.itek.retail.ui.customviews.DashboardDataView
          android:id="@+id/dvInwMainTripsTotal"
          android:layout_width="match_parent"
          android:layout_height="match_parent"
          android:layout_weight="1"
          android:background="@drawable/border_bottom"
          app:label="@string/lbl_total"/>

        <com.itek.retail.ui.customviews.DashboardDataView
          android:id="@+id/dvInwMainTripsCompleted"
          android:layout_width="match_parent"
          android:layout_height="match_parent"
          android:layout_weight="1"
          android:background="@drawable/border_bottom"
          app:label="@string/status_completed"/>

        <com.itek.retail.ui.customviews.DashboardDataView
          android:id="@+id/dvInwMainTripsPending"
          android:layout_width="match_parent"
          android:layout_height="match_parent"
          android:layout_weight="1"
          android:background="@drawable/border_bottom"
          app:label="@string/lbl_mov_pending"/>

      </LinearLayout>

      <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:background="@color/graywhite"
        android:orientation="vertical"
        app:srcCompat="@drawable/border">

        <TextView
          android:id="@+id/lblInwMainHus"
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:background="@drawable/border_bottom"
          android:gravity="center"
          android:padding="@dimen/dp_10"
          android:text="@string/lbl_grn_HUs"
          android:textAppearance="@style/TextStyleSubSubHeader" />

        <com.itek.retail.ui.customviews.DashboardDataView
          android:id="@+id/dvInwMainHusTotal"
          android:layout_width="match_parent"
          android:layout_height="match_parent"
          android:layout_weight="1"
          android:background="@drawable/border_bottom"
          app:label="@string/lbl_total"/>

        <com.itek.retail.ui.customviews.DashboardDataView
          android:id="@+id/dvInwMainHusCompleted"
          android:layout_width="match_parent"
          android:layout_height="match_parent"
          android:layout_weight="1"
          android:background="@drawable/border_bottom"
          app:label="@string/lbl_mov_completed" />

        <com.itek.retail.ui.customviews.DashboardDataView
          android:id="@+id/dvInwMainHusPending"
          android:layout_width="match_parent"
          android:layout_height="match_parent"
          android:layout_weight="1"
          android:background="@drawable/border_bottom"
          app:label="@string/lbl_mov_pending"/>
      </LinearLayout>
    </LinearLayout>

  </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.swiperefreshlayout.widget.SwipeRefreshLayout>
