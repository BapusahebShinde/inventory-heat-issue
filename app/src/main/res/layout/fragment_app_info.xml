  </androidx.appcompat.widget.LinearLayoutCompat>-->

  <ScrollView
    android:layout_width="match_parent"
    android:layout_height="@dimen/dp_0"
    app:layout_constraintBottom_toBottomOf="parent"
    app:layout_constraintLeft_toLeftOf="parent"
    app:layout_constraintRight_toRightOf="parent"
    app:layout_constraintTop_toBottomOf="@id/header">

    <LinearLayout
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:orientation="vertical">

      <TextView
        android:id="@+id/txt_app_info_imei"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:background="@drawable/border_bottom"
        android:gravity="center_horizontal"
        android:padding="@dimen/dp_10"
        android:textAppearance="@style/TextStyleSubHeader" />

      <TextView
        android:id="@+id/txt_app_info_mac_id"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:background="@drawable/border_bottom"
        android:gravity="center_horizontal"
        android:padding="@dimen/dp_10"
        android:textAppearance="@style/TextStyleSubHeader" />

      <TextView
        android:id="@+id/txt_app_info_ip"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:background="@drawable/border_bottom"
        android:gravity="center_horizontal"
        android:padding="@dimen/dp_10"
        android:textAppearance="@style/TextStyleSubHeader" />

      <TextView
        android:id="@+id/txt_app_info_device_serial"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:background="@drawable/border_bottom"
        android:gravity="center_horizontal"
        android:padding="@dimen/dp_10"
        android:textAppearance="@style/TextStyleSubHeader" />

      <TextView
        android:id="@+id/txt_app_info_version"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:background="@drawable/border_bottom"
        android:gravity="center_horizontal"
        android:padding="@dimen/dp_10"
        android:textAppearance="@style/TextStyleSubHeader" />

      <TextView
        android:id="@+id/txt_app_info_reader_sdk_version"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:background="@drawable/border_bottom"
        android:gravity="center_horizontal"
        android:padding="@dimen/dp_10"
        android:textAppearance="@style/TextStyleSubHeader" />

      <TextView
        android:id="@+id/txt_app_info_device_type"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:background="@drawable/border_bottom"
        android:gravity="center_horizontal"
        android:padding="@dimen/dp_10"
        android:textAppearance="@style/TextStyleSubHeader" />

      <LinearLayout
        android:id="@+id/ll_app_info_extra"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"/>

      <TextView
        android:id="@+id/txt_app_info_release_date"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_margin="@dimen/dp_10"
        android:background="@drawable/border_bottom"
        android:gravity="center_horizontal"
        android:textAppearance="@style/TextStyleSubHeader" />

      <TextView
        android:id="@+id/txt_app_info_release_note"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_margin="@dimen/dp_10"
        android:background="@drawable/border_bottom"
        android:gravity="center_horizontal"
        android:textAppearance="@style/TextStyleSubHeader" />

      <TextView
        android:id="@+id/txt_app_info_install_date"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_margin="@dimen/dp_10"
        android:background="@drawable/border_bottom"
        android:gravity="center_horizontal"
        android:textAppearance="@style/TextStyleSubHeader" />

    </LinearLayout>
  </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
