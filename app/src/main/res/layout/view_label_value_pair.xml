<?xml version="1.0" encoding="utf-8"?>

<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
  android:id="@+id/ll_label_values"
  android:layout_width="match_parent"
  android:layout_height="wrap_content"
  android:background="@drawable/border_bottom"
  android:orientation="horizontal">

  <TextView
    android:id="@+id/txt_row_label"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_weight="2"
    android:ellipsize="marquee"
    android:marqueeRepeatLimit="marquee_forever"
    android:paddingLeft="@dimen/dp_2"
    android:singleLine="true"
    android:textAppearance="@style/TextStyleSubSubHeader" />

  <TextView
    android:id="@+id/txt_row_div"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:text=" : "
    android:textAppearance="@style/TextStyleRegular"
    android:visibility="invisible" />

  <TextView
    android:id="@+id/txt_row_value"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_weight="1"
    android:ellipsize="marquee"
    android:gravity="center_vertical"
    android:marqueeRepeatLimit="marquee_forever"
    android:singleLine="true"
    android:textAppearance="@style/TextStyleSubSubHeader" />

</LinearLayout>
