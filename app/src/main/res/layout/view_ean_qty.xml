<?xml version="1.0" encoding="utf-8"?>

<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
  xmlns:app="http://schemas.android.com/apk/res-auto"
  android:layout_width="match_parent"
  android:layout_height="wrap_content"
  android:background="@drawable/border"
  android:orientation="horizontal"
  android:padding="@dimen/dp_2">

  <TextView
    android:id="@+id/txt_ean"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_gravity="center"
    android:layout_margin="@dimen/dp_2"
    android:layout_weight="1"
    android:text="@string/lbl_ean"
    android:textStyle="bold"
    android:textAppearance="@style/TextStyleSubHeader"
    android:textColor="@color/txt_light" />

  <View
    android:background="@color/txtExtraLighterGray"
    android:layout_width="@dimen/dp_1"
    android:layout_height="match_parent"/>

  <TextView
    android:id="@+id/txt_qty"
    style="@style/TextStyleSubHeader"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_gravity="center"
    android:gravity="center"
    android:layout_margin="@dimen/dp_2"
    android:layout_weight="1.25"
    android:text="@string/lbl_qty"
    android:textStyle="bold"
    android:textAppearance="@style/TextStyleSubHeader"
    android:textColor="@color/txt_light" />

</LinearLayout>
