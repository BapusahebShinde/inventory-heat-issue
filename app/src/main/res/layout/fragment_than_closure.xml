<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
  xmlns:app="http://schemas.android.com/apk/res-auto"
  xmlns:bind="http://schemas.android.com/tools"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  android:background="@color/white"
  android:clickable="true"
  android:focusable="true"
  android:orientation="vertical"
  bind:context=".ui.decoding.DecodingStartFragment">

  <include
    android:id="@+id/header"
    layout="@layout/header_title_layout" />

  <com.itek.retail.ui.customviews.PowerView
    android:id="@+id/llSeekbarPower"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="@dimen/dp_15"
    android:visibility="gone"
    app:layout_constraintTop_toBottomOf="@id/header"
    app:pv_max="30"
    app:pv_min="5" />

  <com.itek.retail.ui.customviews.ProductDetailsView
    android:id="@+id/pdv_than"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:layout_constrainedHeight="true"
    app:layout_constraintHeight_max="wrap"
    app:layout_constraintHeight_percent="0.3"
    app:layout_constraintTop_toBottomOf="@id/header" />

  <com.itek.retail.ui.customviews.BtnStartStopView
    android:id="@+id/llBtnStart"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_gravity="center"
    android:layout_weight="1"
    android:gravity="center"
    android:orientation="vertical"
    app:layout_constraintLeft_toLeftOf="parent"
    app:layout_constraintRight_toRightOf="parent"
    android:layout_margin="@dimen/dp_15"
    app:layout_constraintTop_toBottomOf="@id/pdv_than" />

  <TextView
    android:id="@+id/lbl_decoding_start_history"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="@dimen/dp_15"
    android:gravity="center"
    android:text="@string/lbl_encode_history"
    android:textAppearance="@style/TextStyleSubHeader"
    app:layout_constraintLeft_toLeftOf="parent"
    app:layout_constraintRight_toRightOf="parent"
    android:visibility="gone"
    app:layout_constraintTop_toBottomOf="@id/llBtnStart" />

  <androidx.recyclerview.widget.RecyclerView
    android:id="@+id/list_decoding_start_history"
    android:layout_width="match_parent"
    android:layout_height="@dimen/dp_0"
    android:layout_marginLeft="@dimen/dp_15"
    android:layout_marginTop="@dimen/dp_0"
    android:layout_marginRight="@dimen/dp_15"
    android:visibility="gone"
    app:layout_constraintLeft_toLeftOf="parent"
    app:layout_constraintRight_toRightOf="parent"
    app:layout_constraintBottom_toBottomOf="parent"
    app:layout_constraintTop_toBottomOf="@id/lbl_decoding_start_history" />

  <ImageView
    android:id="@+id/img_list_load_more"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:scaleType="fitCenter"
    android:visibility="gone"
    app:layout_constraintBottom_toBottomOf="parent"
    app:layout_constraintTop_toBottomOf="@id/list_decoding_start_history"
    app:srcCompat="@drawable/ic_downarrow" />

</androidx.constraintlayout.widget.ConstraintLayout>
