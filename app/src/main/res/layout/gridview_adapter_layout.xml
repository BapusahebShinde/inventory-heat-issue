<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
  xmlns:app="http://schemas.android.com/apk/res-auto">

  <data>

    <variable
      name="gridMenuViewModel"
      type="com.itek.retail.model.MenuModel" />
  </data>

  <androidx.constraintlayout.widget.ConstraintLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/white"
    android:padding="@dimen/dp_5">

    <ImageView
      android:id="@+id/imgActiveSession"
      android:layout_width="@dimen/dp_0"
      android:layout_height="@dimen/dp_0"
      android:layout_margin="@dimen/dp_15"
      android:scaleType="fitCenter"
      android:visibility="gone"
      app:layout_constraintDimensionRatio="1:1"
      app:layout_constraintRight_toRightOf="parent"
      app:layout_constraintTop_toTopOf="parent"
      app:layout_constraintWidth_default="percent"
      app:layout_constraintWidth_percent="0.10"
      app:srcCompat="@drawable/button_round_red" />

    <LinearLayout
      android:layout_width="match_parent"
      android:layout_height="@dimen/dp_0"
      android:gravity="center"
      android:orientation="vertical"
      app:layout_constraintDimensionRatio="1:1"
      app:layout_constraintTop_toTopOf="parent">

      <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="@dimen/dp_5">

        <ImageView
          android:id="@+id/imgMenuLogo"
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:scaleType="fitCenter" />

        <ImageView
          android:id="@+id/imgMenuSlash"
          android:layout_width="@dimen/dp_0"
          android:layout_height="@dimen/dp_0"
          android:scaleType="fitCenter"
          android:visibility="gone"
          app:layout_constraintBottom_toBottomOf="@id/imgMenuLogo"
          app:layout_constraintLeft_toLeftOf="@id/imgMenuLogo"
          app:layout_constraintRight_toRightOf="@id/imgMenuLogo"
          app:layout_constraintTop_toTopOf="@id/imgMenuLogo"
          app:srcCompat="@drawable/ic_slash_small" />
      </androidx.constraintlayout.widget.ConstraintLayout>

      <TextView
        android:id="@+id/lblMenuTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="@dimen/dp_5"
        android:ellipsize="marquee"
        android:gravity="center"
        android:maxLines="2"
        android:minLines="2"
        android:singleLine="false"
        android:textAppearance="@style/TextStyleRegular" />

    </LinearLayout>
  </androidx.constraintlayout.widget.ConstraintLayout>
</layout>