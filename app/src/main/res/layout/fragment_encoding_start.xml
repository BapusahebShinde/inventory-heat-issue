<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
  xmlns:app="http://schemas.android.com/apk/res-auto"
  xmlns:bind="http://schemas.android.com/tools"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  android:background="@color/white"
  android:clickable="true"
  android:focusable="true"
  android:orientation="vertical"
  bind:context=".ui.encoding.EncodingStartFragment">

  <include
    android:id="@+id/header"
    layout="@layout/header_title_layout" />

  <LinearLayout
    android:id="@+id/llEncodingConfig"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:visibility="gone"
    app:layout_constraintTop_toBottomOf="@id/header">

    <LinearLayout
      android:id="@+id/ll_encoding_config_relation"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_gravity="center"
      android:layout_marginLeft="@dimen/dp_15"
      android:layout_marginRight="@dimen/dp_15"
      android:gravity="center_horizontal"
      android:orientation="horizontal"
      app:layout_constraintBottom_toTopOf="@id/ll_encoding_config_barcoderfidtype"
      app:layout_constraintTop_toBottomOf="@id/lbl_encoding_config_encodingtype">

      <Button
        android:id="@+id/btn_config_relation_one_to_one"
        style="@style/ButtonSelectable"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="@dimen/dp_10"
        android:tag="One-One"
        android:text="@string/btn_encode_config_type_one_to_one" />

      <Button
        android:id="@+id/btn_config_relation_one_to_many"
        style="@style/ButtonSelectable"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="@dimen/dp_10"
        android:tag="One-Many"
        android:text="@string/btn_encode_config_type_one_to_many" />

    </LinearLayout>

    <com.itek.retail.ui.customviews.PowerView
      android:id="@+id/llSeekbarPower"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_margin="@dimen/dp_15"
      android:visibility="gone"
      app:layout_constraintTop_toBottomOf="@id/header"
      app:pv_max="30"
      app:pv_min="5" />

  </LinearLayout>

  <LinearLayout
    android:id="@+id/ll_start_encoding_score"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    app:layout_constraintBottom_toTopOf="@id/ll_verify_encoding_start_main"
    app:layout_constraintTop_toBottomOf="@id/llEncodingConfig">

    <androidx.constraintlayout.widget.ConstraintLayout
      android:id="@+id/cl_start_encoding_ll_score"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:orientation="horizontal">

      <TextView
        style="@style/TextStyleHeader"
        android:id="@+id/txtEncodeUploadedCount"
        android:layout_width="@dimen/dp_0"
        android:layout_height="@dimen/dp_0"
        android:layout_gravity="left"
        android:gravity="center"
        android:text="Uploaded:\n12 / 34"
        android:layout_marginTop="@dimen/dp_5"
        android:layout_marginBottom="@dimen/dp_5"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintRight_toLeftOf="@id/ctw_inventory_start"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintWidth_default="percent"
        app:layout_constraintWidth_percent="0.33" />

      <com.itek.retail.ui.customviews.CountTotalView
          android:id="@+id/ctw_inventory_start"
          android:layout_width="@dimen/dp_0"
          android:layout_height="@dimen/dp_0"
          android:layout_gravity="center"
          android:orientation="vertical"
          android:visibility="visible"
          app:layout_constraintBottom_toBottomOf="parent"
          app:layout_constraintDimensionRatio="1:1"
          app:layout_constraintLeft_toLeftOf="parent"
          app:layout_constraintRight_toRightOf="parent"
          app:layout_constraintTop_toTopOf="parent"
          app:layout_constraintWidth_default="percent"
          app:layout_constraintWidth_percent="0.37"
          app:textSizeScore="@dimen/sp_22"
          app:textSizeTotal="@dimen/sp_20"
          app:score="0"/>

      <SeekBar
        android:id="@+id/seek_encoding_start_target"
        android:layout_width="@dimen/dp_0"
        android:layout_height="@dimen/dp_0"
        android:layout_gravity="right"
        android:layout_marginTop="@dimen/dp_5"
        android:layout_marginBottom="@dimen/dp_5"
        android:progress="25"
        android:progressDrawable="@drawable/seekbar_target"
        android:rotation="270"
        android:visibility="visible"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintLeft_toRightOf="@id/ctw_inventory_start"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintWidth_default="percent"
        app:layout_constraintWidth_percent="0.33" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <TextView
      android:id="@+id/lbl_encoding_total"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_gravity="center"
      android:layout_marginLeft="@dimen/dp_15"
      android:layout_marginRight="@dimen/dp_15"
      android:background="@drawable/border_bottom"
      android:gravity="center"
      android:paddingBottom="@dimen/dp_2"
      android:text="@string/lbl_encode_target"
      android:textColor="@color/txt_regular"
      android:textStyle="normal"
      app:layout_constraintBottom_toTopOf="@id/scan_encoding_start_rfid"
      app:layout_constraintTop_toBottomOf="@id/ll_start_encoding_score" />

    <Button
      style="@style/Button"
      android:id="@+id/btn_verify_encoding"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:layout_marginLeft="@dimen/dp_10"
      android:layout_marginRight="@dimen/dp_10"
      android:gravity="center"
      android:text="@string/btn_verify_enc"
      android:textAppearance="@style/TextStyleSubHeader"
      app:layout_constraintLeft_toLeftOf="parent"
      app:layout_constraintRight_toRightOf="parent"
      android:visibility="gone"
      app:layout_constraintBottom_toTopOf="@id/ll_verify_encoding_start_main"
      app:layout_constraintTop_toBottomOf="@id/ll_start_encoding_score" />

    <LinearLayout
      android:id="@+id/ll_encoding_start_barcoderfid_scan"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginLeft="@dimen/dp_15"
      android:layout_marginTop="@dimen/dp_15"
      android:layout_marginRight="@dimen/dp_15"
      android:background="@color/white"
      android:orientation="vertical"
      android:visibility="gone"
      app:layout_constraintTop_toBottomOf="@id/ll_start_encoding_score">

      <com.itek.retail.ui.customviews.ScanCodesInputAndKeypadView
        android:id="@+id/start_encoding_linear_layout_barcode"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />
    </LinearLayout>

  </LinearLayout>

  <LinearLayout
    android:id="@+id/ll_verify_encoding_start_main"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginLeft="@dimen/dp_15"
    android:layout_marginTop="@dimen/dp_5"
    android:layout_marginRight="@dimen/dp_15"
    android:orientation="vertical"
    app:layout_constraintBottom_toTopOf="@id/lbl_encoding_start_history"
    app:layout_constraintTop_toBottomOf="@id/ll_start_encoding_score">

    <com.itek.retail.ui.customviews.ScanCodesInputAndKeypadView
      android:id="@+id/scan_encoding_start_rfid"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      app:layout_constraintBottom_toTopOf="@id/llBtnStart"
      app:layout_constraintTop_toBottomOf="@id/ll_start_encoding_score" />

    <com.itek.retail.ui.customviews.DateInputView
      android:id="@+id/divFifo"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:hint="@string/lbl_fifo_date"
      app:label="@string/lbl_fifo_date" />

    <com.itek.retail.ui.customviews.BtnStartStopView
      android:id="@+id/llBtnStart"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:layout_gravity="center"
      android:layout_weight="1"
      android:gravity="center"
      android:orientation="vertical" />

  </LinearLayout>

  <TextView
    android:id="@+id/lbl_encoding_start_history"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="@dimen/dp_15"
    android:gravity="center"
    android:text="@string/lbl_encode_history"
    android:textAppearance="@style/TextStyleSubHeader"
    app:layout_constraintBottom_toTopOf="@id/list_encoding_start_history"
    app:layout_constraintTop_toBottomOf="@id/ll_verify_encoding_start_main" />

  <androidx.recyclerview.widget.RecyclerView
    android:id="@+id/list_encoding_start_history"
    android:layout_width="match_parent"
    android:layout_height="@dimen/dp_0"
    android:layout_marginLeft="@dimen/dp_15"
    android:layout_marginTop="@dimen/dp_0"
    android:layout_marginRight="@dimen/dp_15"
    app:layout_constraintBottom_toBottomOf="parent"
    app:layout_constraintTop_toBottomOf="@id/lbl_encoding_start_history" />

  <ImageView
    android:id="@+id/img_list_load_more"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:scaleType="fitCenter"
    android:visibility="gone"
    app:layout_constraintBottom_toBottomOf="parent"
    app:layout_constraintTop_toBottomOf="@id/list_encoding_start_history"
    app:srcCompat="@drawable/ic_downarrow" />


  <LinearLayout
    android:id="@+id/ll_verify_encoding_found_total"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginLeft="@dimen/dp_15"
    android:layout_marginRight="@dimen/dp_15"
    android:layout_marginBottom="@dimen/dp_15"
    android:orientation="horizontal"
    app:layout_constraintBottom_toTopOf="@id/list_verify_encoded"
    app:layout_constraintLeft_toLeftOf="parent"
    app:layout_constraintRight_toRightOf="parent"
    app:layout_constraintTop_toBottomOf="@id/llEncodingConfig">

    <com.itek.retail.ui.customviews.DashboardDataView
      android:id="@+id/ddv_verify_encoding_total_found"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_weight="1"
      android:gravity="center"
      android:padding="@dimen/dp_0"
      android:text="0/0"
      android:textSize="@dimen/sp_28"
      app:isShowPercent="false"
      app:isUseSplitLabels="true"
      app:isUseSplitViews="false"
      app:label="@string/lbl_found_total"
      app:layout_constraintBottom_toTopOf="@id/list_search_unencoded"
      app:layout_constraintLeft_toLeftOf="parent"
      app:layout_constraintRight_toRightOf="parent"
      app:layout_constraintTop_toBottomOf="@id/spin_location" />

    <com.itek.retail.ui.customviews.BtnStartStopView
      android:id="@+id/llBtnStartInv"
      android:layout_width="match_parent"
      android:layout_height="match_parent"
      android:layout_weight="1"
      android:gravity="center"
      android:orientation="vertical" />

  </LinearLayout>

  <androidx.recyclerview.widget.RecyclerView
    android:id="@+id/list_verify_encoded"
    android:layout_width="match_parent"
    android:layout_height="@dimen/dp_0"
    android:layout_marginLeft="@dimen/dp_15"
    android:layout_marginRight="@dimen/dp_15"
    android:layout_marginBottom="@dimen/dp_5"
    android:scrollbars="vertical"
    app:layout_behavior="@string/appbar_scrolling_view_behavior"
    app:layout_constraintBottom_toBottomOf="parent"
    app:layout_constraintLeft_toLeftOf="parent"
    app:layout_constraintRight_toRightOf="parent"
    app:layout_constraintTop_toBottomOf="@id/ll_verify_encoding_found_total" />

</androidx.constraintlayout.widget.ConstraintLayout>
