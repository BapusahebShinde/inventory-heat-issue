<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:bind="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:clickable="true"
    android:orientation="vertical"
    bind:context="com.itek.retail.ui.inventory.InventoryAddFragment">

    <include
        android:id="@+id/header"
        layout="@layout/header_title_layout" />

    <com.itek.retail.ui.customviews.HeaderSpinner
        android:id="@+id/spin_inventory_start_location"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginLeft="@dimen/dp_15"
        android:layout_marginRight="@dimen/dp_15"
        android:layout_weight="1"
        android:background="@drawable/border_bottom"
        app:label="@string/lbl_location"
        app:layout_constraintTop_toBottomOf="@id/header" />

    <com.itek.retail.ui.customviews.PowerView
        android:id="@+id/llSeekbarPower"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:gravity="center"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/spin_inventory_start_location"
        app:pv_max="30"
        app:pv_min="5" />

    <com.itek.retail.ui.customviews.CountTotalView
        android:id="@+id/ctw_inventory_start"
        android:layout_width="@dimen/dp_0"
        android:layout_height="@dimen/dp_0"
        android:layout_gravity="center"
        android:layout_marginTop="@dimen/dp_15"
        app:layout_constraintBottom_toTopOf="@id/ll_inventory_start_session_lbls"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toBottomOf="@id/llSeekbarPower"
        app:layout_constraintWidth_default="percent"
        app:layout_constraintWidth_percent="0.5"
        app:score="0" />

    <com.itek.retail.ui.customviews.CountTotalView
        android:id="@+id/ctw_alien"
        layout_marginLeft="@dimen/dp_15"
        android:layout_width="@dimen/dp_0"
        android:layout_height="@dimen/dp_0"
        android:layout_gravity="center"
        android:layout_marginBottom="@dimen/dp_10"
        android:background="@color/transparent"
        app:isShowProgress="false"
        app:layout_constraintBottom_toBottomOf="@id/ctw_inventory_start"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintWidth_default="percent"
        app:layout_constraintWidth_percent="0.20"
        app:score="0"
        app:textAppearanceTotal="@style/TextStyleRegularError"
        app:textSizeScore="@dimen/sp_18"
        app:total="@string/lbl_alien" />

    <com.itek.retail.ui.customviews.CountTotalView
        android:id="@+id/ctw_unencoded"
        android:layout_width="@dimen/dp_0"
        android:layout_height="@dimen/dp_0"
        android:layout_gravity="center"
        android:layout_marginRight="@dimen/dp_15"
        android:layout_marginBottom="@dimen/dp_10"
        android:background="@color/transparent"
        app:isShowProgress="false"
        app:layout_constraintBottom_toBottomOf="@id/ctw_inventory_start"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintWidth_default="percent"
        app:layout_constraintWidth_percent="0.20"
        app:score="0"
        app:textAppearanceTotal="@style/TextStyleRegularError"
        app:textSizeScore="@dimen/sp_18"
        app:textSizeTotal="@dimen/sp_10"
        app:total="@string/lbl_unencoded" />

    <LinearLayout
        android:id="@+id/ll_inventory_start_session_lbls"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="horizontal"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/llBtnStart"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toBottomOf="@id/ctw_inventory_start">

        <ImageView
            android:id="@+id/img_inventory_start_info"
            android:layout_width="@dimen/dp_20"
            android:layout_height="@dimen/dp_20"
            android:layout_gravity="top"
            android:layout_marginTop="@dimen/dp_5"
            android:layout_marginRight="@dimen/dp_5"
            android:layout_toRightOf="@id/txt_inventory_start_session"
            android:longClickable="false"
            android:scaleType="fitCenter"
            android:visibility="visible"
            app:srcCompat="@drawable/ic_inv_date_info" />
    </LinearLayout>

    <com.itek.retail.ui.customviews.BtnStartStopView
        android:id="@+id/llBtnStart"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toBottomOf="@id/ll_inventory_start_session_lbls" />

    <com.itek.retail.ui.customviews.BtnSwipeUploadView
      android:id="@+id/btnUpload"
      android:layout_width="wrap_content"
      android:layout_height="@dimen/dp_0"
      android:visibility="gone"
      app:layout_constraintBottom_toBottomOf="parent"
      app:layout_constraintRight_toRightOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
