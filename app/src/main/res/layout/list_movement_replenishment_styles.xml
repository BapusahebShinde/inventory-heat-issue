<?xml version="1.0" encoding="utf-8"?>

<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
  xmlns:app="http://schemas.android.com/apk/res-auto"
  android:id="@+id/ll_verify_encoding_product_info"
  android:layout_width="match_parent"
  android:layout_height="wrap_content"
  android:layout_margin="@dimen/dp_5"
  android:orientation="vertical">

  <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/border_light"
    android:orientation="horizontal"
    android:padding="@dimen/dp_5">

    <ImageView
      android:id="@+id/img_product"
      android:layout_width="match_parent"
      android:layout_height="match_parent"
      android:layout_gravity="center"
      android:layout_weight="7"
      android:padding="@dimen/dp_1"
      android:scaleType="fitCenter"
      app:srcCompat="@drawable/ic_no_img" />

    <LinearLayout
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_gravity="center"
      android:layout_weight="1"
      android:orientation="vertical"
      android:paddingLeft="@dimen/dp_2"
      android:paddingTop="@dimen/dp_2"
      android:paddingBottom="@dimen/dp_2">

      <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/dp_half"
        android:orientation="horizontal">

        <TextView
          android:id="@+id/txt_product_ean"
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:layout_marginRight="@dimen/dp_1"
          android:layout_weight="1.25"
          android:ellipsize="marquee"
          android:gravity="left|center_vertical"
          android:singleLine="true"
          android:text="@string/txt_ean"
          android:textAppearance="@style/TextStyleSmall" />

        <TextView
          android:id="@+id/txt_product_loc"
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:layout_marginLeft="@dimen/dp_1"
          android:layout_marginRight="@dimen/dp_1"
          android:layout_weight="2"
          android:ellipsize="marquee"
          android:gravity="left|center_vertical"
          android:singleLine="true"
          android:text="@string/txt_loc"
          android:textAppearance="@style/TextStyleSmall" />

        <TextView
          android:id="@+id/txt_product_qty"
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:layout_marginLeft="@dimen/dp_1"
          android:layout_weight="2"
          android:ellipsize="marquee"
          android:gravity="center|center_vertical"
          android:singleLine="true"
          android:text="@string/txt_qty"
          android:textAppearance="@style/TextStyleSmall" />

      </LinearLayout>

      <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dp_half"
        android:orientation="horizontal">

        <TextView
          android:id="@+id/txt_product_name"
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:layout_marginRight="@dimen/dp_1"
          android:layout_weight="1.25"
          android:ellipsize="marquee"
          android:gravity="left|center_vertical"
          android:singleLine="true"
          android:text="@string/txt_name"
          android:textAppearance="@style/TextStyleSmall" />

        <TextView
          android:id="@+id/txt_product_size"
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:layout_marginLeft="@dimen/dp_1"
          android:layout_marginRight="@dimen/dp_1"
          android:layout_weight="2"
          android:ellipsize="marquee"
          android:gravity="left|center_vertical"
          android:singleLine="true"
          android:text="@string/txt_size"
          android:textAppearance="@style/TextStyleSmall" />

        <TextView
          android:id="@+id/txt_product_color"
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:layout_marginLeft="@dimen/dp_1"
          android:layout_weight="2"
          android:ellipsize="marquee"
          android:gravity="center|center_vertical"
          android:singleLine="true"
          android:text="@string/icon_circle"
          android:textAppearance="@style/TextStyleSmallAwesome" />
      </LinearLayout>

      <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:visibility="gone">

        <TextView
          android:id="@+id/txt_product_extra"
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:layout_margin="@dimen/dp_2"
          android:layout_weight="2.75"
          android:gravity="left|center_vertical"
          android:text=""
          android:textColor="@color/txtDarkGray" />

      </LinearLayout>
    </LinearLayout>
  </LinearLayout>

</LinearLayout>
