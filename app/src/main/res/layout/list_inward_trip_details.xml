<?xml version="1.0" encoding="utf-8"?>

<layout xmlns:android="http://schemas.android.com/apk/res/android"
  xmlns:app="http://schemas.android.com/apk/res-auto">

  <data>

    <variable
      name="storeTripDetailsData"
      type="com.itek.retail.ui.inward.grn.StoreTripDetailsData" />
  </data>

  <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="@dimen/dp_5"
    android:visibility="visible"
    app:layout_constraintTop_toBottomOf="@id/ll_grn_trip_header_val">

    <TextView
      android:id="@+id/textHuNumber"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_gravity="center"
      android:layout_weight="1"
      android:gravity="center"
      android:text="@string/lbl_grn_hu_no"
      android:textAppearance="@style/TextStyleNumber"
      android:textSize="@dimen/sp_14" />

    <TextView
      android:id="@+id/textHuQty"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_gravity="center"
      android:layout_weight="1.5"
      android:gravity="center"
      android:text="@string/lbl_article_qty"
      android:textAppearance="@style/TextStyleNumber"
      android:textSize="@dimen/sp_14" />

    <LinearLayout
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_weight="1.5"
      android:background="@color/graywhite"
      android:orientation="horizontal"
      android:padding="@dimen/dp_5"
      android:visibility="visible">

      <TextView
        android:id="@+id/textStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_weight="1"
        android:gravity="center"
        android:text="@string/lbl_hu_status"
        android:textAppearance="@style/TextStyleNumber"
        android:textSize="@dimen/sp_14"
        android:visibility="visible" />

      <ImageView
        android:id="@+id/imgStatus"
        android:layout_width="match_parent"
        android:layout_height="@dimen/dp_30"
        android:layout_gravity="end"
        android:layout_weight="1.8"
        android:gravity="end"
        android:visibility="gone"
        app:srcCompat="@drawable/dummy_white_background" />

      <ImageView
        android:id="@+id/imgInfo"
        android:layout_width="@dimen/dp_30"
        android:layout_height="@dimen/dp_30"
        android:layout_gravity="center"
        android:layout_marginLeft="@dimen/dp_5"
        android:layout_marginRight="@dimen/dp_5"
        android:gravity="center"
        android:visibility="visible"
        app:srcCompat="@drawable/dummy_white_background" />
    </LinearLayout>
  </LinearLayout>

</layout>