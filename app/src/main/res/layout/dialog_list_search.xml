<?xml version="1.0" encoding="utf-8"?>
<com.itek.retail.ui.customviews.MaxHeightLinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
  xmlns:app="http://schemas.android.com/apk/res-auto"
  android:layout_width="match_parent"
  android:layout_height="wrap_content"
  android:layout_gravity="top"
  android:background="@color/white"
  android:gravity="top"
  android:orientation="vertical"
  android:paddingTop="@dimen/dp_5"
  android:paddingBottom="@dimen/dp_5">

  <EditText
    android:id="@+id/edt_search"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_gravity="center_vertical"
    android:layout_marginLeft="@dimen/dp_5"
    android:layout_marginRight="@dimen/dp_5"
    android:layout_marginBottom="@dimen/dp_1"
    android:background="@drawable/edit_text_border"
    android:digits="@string/onlyAlphaDigitsSpaceDot"
    android:hint="@string/hint_spin_search"
    android:imeOptions="actionSearch"
    android:inputType="text"
    android:maxLength="50"
    android:maxLines="1"
    android:padding="@dimen/dp_5"
    android:singleLine="true"
    android:textAppearance="@style/TextStyleRegular"
    app:drawableRightCompat="@drawable/ic_act_ser"
    app:layout_constraintBottom_toTopOf="@id/list_dropdown_dialog"
    app:layout_constraintLeft_toLeftOf="parent"
    app:layout_constraintRight_toRightOf="parent"
    app:layout_constraintTop_toTopOf="parent" />

  <androidx.recyclerview.widget.RecyclerView
    android:id="@+id/list_dropdown_dialog"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="@dimen/dp_1"
    app:layout_constraintBottom_toBottomOf="parent"
    app:layout_constraintLeft_toLeftOf="parent"
    app:layout_constraintRight_toRightOf="parent"
    app:layout_constraintTop_toBottomOf="@id/edt_search" />

</com.itek.retail.ui.customviews.MaxHeightLinearLayout>