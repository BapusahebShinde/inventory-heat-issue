<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
  xmlns:app="http://schemas.android.com/apk/res-auto"
  xmlns:bind="http://schemas.android.com/tools"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  android:background="@color/white"
  android:clickable="true"
  bind:context=".ui.outward.OutwardPickStartViewModel">

  <include
    android:id="@+id/header"
    layout="@layout/header_title_layout" />

  <LinearLayout
    android:id="@+id/llTripHu"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="@dimen/dp_2"
    android:background="@drawable/border_bottom"
    android:gravity="center"
    android:orientation="horizontal"
    app:layout_constraintTop_toBottomOf="@+id/header">

    <TextView
      android:id="@+id/txt_trip_number_scan"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:layout_margin="@dimen/dp_5"
      android:layout_weight="1"
      android:ellipsize="marquee"
      android:fadingEdge="horizontal"
      android:gravity="center"
      android:marqueeRepeatLimit="marquee_forever"
      android:scrollHorizontally="true"
      android:singleLine="true"
      android:text="@string/txt_trip"
      android:textAppearance="@style/TextStyleSubSubHeader" />

    <TextView
      android:id="@+id/txt_HU_number_scan"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:layout_margin="@dimen/dp_5"
      android:layout_weight="1"
      android:ellipsize="marquee"
      android:fadingEdge="horizontal"
      android:gravity="center"
      android:marqueeRepeatLimit="marquee_forever"
      android:scrollHorizontally="true"
      android:singleLine="true"
      android:text="@string/txt_hu"
      android:textAppearance="@style/TextStyleSubSubHeader" />
  </LinearLayout>

  <com.itek.retail.ui.customviews.ProductDetailsView
    android:id="@+id/pdv_outward_start"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:visibility="visible"
    app:layout_constrainedHeight="true"
    app:layout_constraintHeight_max="wrap"
    app:layout_constraintHeight_percent="0.3"
    app:layout_constraintTop_toBottomOf="@id/llTripHu" />

  <RadioGroup
    android:id="@+id/rgPickSearchType"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="@dimen/dp_0"
    android:background="@drawable/border_bottom"
    android:orientation="horizontal"
    app:layout_constraintTop_toBottomOf="@id/pdv_outward_start">

    <View
      android:layout_width="match_parent"
      android:layout_height="match_parent"
      android:layout_weight="1.3" />

    <RadioButton
      android:id="@+id/rbSearch"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_margin="@dimen/dp_5"
      android:layout_weight="1"
      android:checked="true"
      android:ellipsize="marquee"
      android:marqueeRepeatLimit="marquee_forever"
      android:singleLine="true"
      android:text="@string/search" />

    <View
      android:layout_width="match_parent"
      android:layout_height="match_parent"
      android:layout_weight="1.1" />

    <RadioButton
      android:id="@+id/rbPick"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_margin="@dimen/dp_5"
      android:layout_weight="1"
      android:ellipsize="marquee"
      android:marqueeRepeatLimit="marquee_forever"
      android:singleLine="true"
      android:text="@string/pick" />

    <View
      android:layout_width="match_parent"
      android:layout_height="match_parent"
      android:layout_weight="1.3" />
  </RadioGroup>

  <TextView
    android:id="@+id/txt_picked"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginLeft="@dimen/dp_15"
    android:layout_marginTop="@dimen/dp_5"
    android:layout_marginRight="@dimen/dp_15"
    android:layout_marginBottom="@dimen/dp_5"
    android:gravity="left"
    android:textAppearance="@style/TextStyleSubHeader"
    android:visibility="visible"
    app:layout_constraintTop_toBottomOf="@id/rgPickSearchType" />

  <androidx.constraintlayout.widget.ConstraintLayout
    android:id="@+id/llCircle"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    app:layout_constraintBottom_toTopOf="@id/llBtnStart"
    app:layout_constraintLeft_toLeftOf="parent"
    app:layout_constraintRight_toRightOf="parent"
    app:layout_constraintTop_toBottomOf="@id/rgPickSearchType">

    <com.itek.retail.ui.customviews.speedviewlib.PointerSpeedometer
      android:id="@+id/clOutwardSearch"
      android:layout_width="@dimen/dp_0"
      android:layout_height="@dimen/dp_0"
      app:layout_constraintBottom_toBottomOf="parent"
      app:layout_constraintDimensionRatio="1:1"
      app:layout_constraintLeft_toLeftOf="parent"
      app:layout_constraintRight_toRightOf="parent"
      app:layout_constraintTop_toTopOf="parent"
      app:layout_constraintWidth_default="percent"
      app:layout_constraintWidth_percent="0.45" />

    <androidx.constraintlayout.widget.ConstraintLayout
      android:id="@+id/clOutwardPick"
      android:layout_width="@dimen/dp_0"
      android:layout_height="@dimen/dp_0"
      android:layout_gravity="center"
      android:background="@drawable/circular_shape"
      android:orientation="vertical"
      android:visibility="gone"
      app:layout_constraintBottom_toBottomOf="parent"
      app:layout_constraintDimensionRatio="1:1"
      app:layout_constraintLeft_toLeftOf="parent"
      app:layout_constraintRight_toRightOf="parent"
      app:layout_constraintTop_toTopOf="parent"
      app:layout_constraintWidth_default="percent"
      app:layout_constraintWidth_percent="0.45">

      <TextView
        android:id="@+id/txtOutwardScoreCount"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:layout_gravity="center_vertical"
        android:gravity="center"
        android:text="0"
        android:textAppearance="@style/TextStyleNumber"
        app:layout_constraintBottom_toTopOf="@id/div_inv_start_score"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent" />

      <View
        android:id="@+id/div_inv_start_score"
        android:layout_width="@dimen/dp_0"
        android:layout_height="@dimen/dp_1"
        android:layout_gravity="center"
        android:background="@color/txtExtraLighterGray"
        android:visibility="visible"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintWidth_default="percent"
        app:layout_constraintWidth_percent="0.6" />

      <TextView
        android:id="@+id/txtOutwardStartTotal"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:layout_gravity="center_vertical"
        android:gravity="center"
        android:textAppearance="@style/TextStyleNumber"
        android:visibility="visible"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toBottomOf="@id/div_inv_start_score" />

      <ImageView
        android:id="@+id/imgOutwardStartInfo"
        android:layout_width="@dimen/dp_20"
        android:layout_height="@dimen/dp_20"
        android:layout_alignParentRight="true"
        android:layout_gravity="right"
        android:layout_marginTop="@dimen/dp_5"
        android:layout_marginRight="@dimen/dp_5"
        android:layout_toRightOf="@id/txtOutwardStartTotal"
        android:longClickable="false"
        android:scaleType="fitCenter"
        android:visibility="gone"
        app:layout_constraintLeft_toRightOf="@id/txtOutwardStartTotal"
        app:layout_constraintTop_toBottomOf="@id/div_inv_start_score"
        app:srcCompat="@drawable/ic_inv_date_info" />

      <com.itek.retail.ui.customviews.custprogress.CircularProgressBar
        android:id="@+id/progressOutwardStart"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="@dimen/dp_0"
        android:layout_height="@dimen/dp_0"
        android:layout_gravity="center"
        android:visibility="visible"
        app:cpb_background_progressbar_color="@color/transparent"
        app:cpb_background_progressbar_width="@dimen/progress_width"
        app:cpb_percent_shape="@layout/custom_progress"
        app:cpb_percent_shape_enabled="true"
        app:cpb_percent_shape_size="@dimen/dp_25"
        app:cpb_percent_text_view_id="@id/txt_progress"
        app:cpb_progress="0"
        app:cpb_progress_direction="to_right"
        app:cpb_progressbar_color="?attr/colorAccent"
        app:cpb_progressbar_width="@dimen/progress_width"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.0" />
    </androidx.constraintlayout.widget.ConstraintLayout>
  </androidx.constraintlayout.widget.ConstraintLayout>

  <com.itek.retail.ui.customviews.BtnStartStopView
    android:id="@+id/llBtnStart"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:gravity="center"
    app:layout_constraintBottom_toBottomOf="parent"
    app:layout_constraintLeft_toLeftOf="parent"
    app:layout_constraintRight_toRightOf="parent"
    app:layout_constraintTop_toBottomOf="@id/llCircle" />

  <com.google.android.material.floatingactionbutton.FloatingActionButton
    android:id="@+id/btnUpload"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_marginRight="@dimen/dp_5"
    android:layout_marginBottom="@dimen/dp_5"
    android:visibility="gone"
    app:backgroundTint="@color/white"
    app:layout_constraintRight_toRightOf="parent"
    app:layout_constraintTop_toTopOf="@id/btnSwipeUpload"
    app:srcCompat="@drawable/ic_upload" />

  <com.itek.retail.ui.customviews.swipeButton.ProSwipeButtonVar
    android:id="@+id/btnSwipeUpload"
    android:layout_width="@dimen/dp_0"
    android:layout_height="@dimen/dp_0"
    android:layout_marginLeft="@dimen/dp_5"
    android:layout_marginRight="@dimen/dp_5"
    android:layout_marginBottom="@dimen/dp_5"
    android:background="@drawable/bg_white_red"
    android:clickable="true"
    android:visibility="gone"
    app:btn_text=""
    app:layout_constraintBottom_toBottomOf="parent"
    app:layout_constraintHeight_default="percent"
    app:layout_constraintHeight_percent="0.25"
    app:layout_constraintLeft_toLeftOf="@id/btnUpload"
    app:layout_constraintRight_toRightOf="@id/btnUpload"
    app:layout_constraintWidth_default="percent"
    app:layout_constraintWidth_percent="0.05" />

  <com.google.android.material.floatingactionbutton.FloatingActionButton
    android:id="@+id/btnOutwardPick"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_margin="@dimen/dp_15"
    android:visibility="gone"
    app:backgroundTint="@color/white"
    app:layout_constraintBottom_toBottomOf="parent"
    app:layout_constraintLeft_toLeftOf="parent"
    app:layout_constraintRight_toLeftOf="@id/llBtnStart"
    app:layout_constraintTop_toBottomOf="@id/llCircle"
    app:srcCompat="@drawable/ic_swipe_arrow" />
</androidx.constraintlayout.widget.ConstraintLayout>
