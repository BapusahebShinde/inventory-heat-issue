<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
  xmlns:app="http://schemas.android.com/apk/res-auto"
  xmlns:bind="http://schemas.android.com/tools"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  android:background="@color/white"
  android:clickable="true"
  bind:context=".ui.movement.MovementStartFragment">

  <include
    android:id="@+id/header"
    layout="@layout/header_title_layout" />

  <LinearLayout
    android:id="@+id/ll_movement_zones"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginLeft="@dimen/dp_15"
    android:layout_marginRight="@dimen/dp_15"
    android:background="@drawable/border_bottom"
    android:orientation="horizontal"
    app:layout_constraintTop_toBottomOf="@id/header">

    <com.itek.retail.ui.customviews.ScanCodesInputAndKeypadView
      android:id="@+id/txt_movement_ean"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_weight="1"
      android:padding="@dimen/dp_15"
      android:visibility="gone"
      app:isShowClearLogo="false"
      app:isShowKeyboard="false"
      app:layout_constraintTop_toBottomOf="@id/ll_movement_zones" />

    <com.itek.retail.ui.customviews.HeaderSpinner
      android:id="@+id/spin_source_zone"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_gravity="center"
      android:layout_weight="1"
      android:background="@drawable/border_right"
      app:label="@string/lbl_source_loc" />

    <com.itek.retail.ui.customviews.HeaderSpinner
      android:id="@+id/spin_destination_zone"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_gravity="center"
      android:layout_weight="1"
      app:label="@string/lbl_destination_loc" />

  </LinearLayout>

  <com.itek.retail.ui.customviews.PowerView
    android:id="@+id/llSeekbarPower"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="@dimen/dp_5"
    android:visibility="gone"
    app:layout_constraintTop_toBottomOf="@id/ll_movement_zones"
    app:pv_max="15"
    app:pv_min="5" />

  <com.itek.retail.ui.customviews.BtnStartStopView
    android:id="@+id/llBtnStart"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:gravity="center"
    app:layout_constraintLeft_toLeftOf="parent"
    app:layout_constraintRight_toRightOf="parent"
    app:layout_constraintTop_toBottomOf="@id/llSeekbarPower" />

  <TextView
    android:id="@+id/txt_movement_total"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginLeft="@dimen/dp_15"
    android:layout_marginTop="@dimen/dp_5"
    android:layout_marginRight="@dimen/dp_15"
    android:layout_marginBottom="@dimen/dp_5"
    android:gravity="center"
    android:textAppearance="@style/TextStyleHeader"
    app:layout_constraintBottom_toTopOf="@id/btnSwipeUpload"
    app:layout_constraintTop_toBottomOf="@id/llBtnStart" />

  <com.itek.retail.ui.customviews.swipeButton.ProSwipeButton
    android:id="@+id/btnSwipeUpload"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:clickable="false"
    android:visibility="gone"
    app:btn_text="Swipe To Move"
    app:layout_constraintLeft_toLeftOf="parent"
    app:layout_constraintRight_toRightOf="parent"
    app:layout_constraintTop_toBottomOf="@id/txt_movement_total" />

  <androidx.recyclerview.widget.RecyclerView
    android:id="@+id/list_movement_ean"
    android:layout_width="match_parent"
    android:layout_height="@dimen/dp_0"
    android:layout_marginLeft="@dimen/dp_15"
    android:layout_marginRight="@dimen/dp_15"
    android:layout_marginBottom="@dimen/dp_15"
    app:layout_behavior="@string/appbar_scrolling_view_behavior"
    app:layout_constraintBottom_toBottomOf="parent"
    app:layout_constraintLeft_toLeftOf="parent"
    app:layout_constraintRight_toRightOf="parent"
    app:layout_constraintTop_toBottomOf="@id/btnSwipeUpload" />

</androidx.constraintlayout.widget.ConstraintLayout>
